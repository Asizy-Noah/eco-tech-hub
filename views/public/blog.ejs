<section class="relative pt-40 pb-16 md:pt-48 md:pb-24 px-4 sm:px-6 lg:px-8 max-w-[1400px] mx-auto text-center overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-full opacity-[0.03] dark:opacity-[0.05] pointer-events-none" style="background-image: radial-gradient(#10b981 1px, transparent 1px); background-size: 30px 30px;"></div>
    
    <div class="relative z-10" x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)">
        <h1 class="text-5xl sm:text-6xl md:text-8xl font-black tracking-tighter text-black dark:text-white mb-6 transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]"
            :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            Sustainability <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-eco-500">Journal.</span>
        </h1>
        <p class="text-lg md:text-xl text-black/60 dark:text-white/60 max-w-2xl mx-auto transition-all duration-1000 delay-100 ease-[cubic-bezier(0.16,1,0.3,1)]"
           :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            Insights, research, and thoughts on eco-friendly technology, sustainable architecture, and the future of the web.
        </p>
    </div>
</section>

<section class="pb-32 px-4 sm:px-6 lg:px-8 max-w-[1200px] mx-auto relative z-10">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
        <% if (blogs && blogs.length > 0) { %>
            <% blogs.forEach((blog, index) => { %>
                
                <% 
                    let excerpt = "Read the full publication...";
                    try {
                        const blocks = JSON.parse(blog.content);
                        const textBlock = blocks.find(b => b.type === 'intro' || b.type === 'paragraph');
                        if (textBlock && textBlock.content) {
                            excerpt = textBlock.content.replace(/<[^>]*>?/gm, '').substring(0, 160) + '...';
                        }
                    } catch(e) {}
                %>

                <div x-data="{ shown: false }" x-intersect.once.margin.-50px="shown = true" 
                     class="group block transition-all duration-1000 ease-out"
                     style="transition-delay: <%= index * 100 %>ms;"
                     :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-16'">
                    
                    <a href="/blog/<%= blog.slug %>" class="block bg-black/5 dark:bg-[#111111] p-8 md:p-10 rounded-[2.5rem] border border-black/5 dark:border-white/5 hover:border-black/20 dark:hover:border-white/20 hover:bg-black/10 dark:hover:bg-[#1a1a1a] transition-all duration-500 h-full flex flex-col">
                        
                        <div class="flex items-center gap-4 mb-6">
                            <div class="px-3 py-1 rounded-full bg-white dark:bg-black border border-black/10 dark:border-white/10 text-[10px] font-bold uppercase tracking-widest text-black/60 dark:text-white/60">
                                Article
                            </div>
                            <span class="text-xs font-bold text-black/40 dark:text-white/40 uppercase tracking-widest">
                                <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                            </span>
                        </div>

                        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-black dark:text-white mb-6 group-hover:text-purple-500 transition-colors leading-[1.1]">
                            <%= blog.title %>
                        </h2>
                        
                        <p class="text-black/60 dark:text-white/60 text-base leading-relaxed mb-8 flex-grow">
                            <%= excerpt %>
                        </p>

                        <div class="flex items-center gap-2 font-bold text-sm uppercase tracking-widest text-black dark:text-white group-hover:text-purple-500 transition-colors mt-auto">
                            Read Publication <i class='bx bx-right-arrow-alt text-xl group-hover:translate-x-2 transition-transform'></i>
                        </div>
                    </a>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full text-center text-black/40 dark:text-white/40 py-20 font-medium">No journal entries published yet.</div>
        <% } %>
    </div>
</section>