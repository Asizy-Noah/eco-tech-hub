<!-- Hero Section -->
<section class="relative min-h-screen flex items-center justify-center overflow-hidden px-3 sm:px-6 lg:px-8 py-12 sm:py-20 bg-white dark:bg-black">
  
  <!-- Animated Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-1/4 left-10 w-64 sm:w-96 h-64 sm:h-96 bg-eco-500/15 dark:bg-eco-500/8 rounded-full blur-3xl sm:blur-[100px] animate-float" style="animation-duration: 6s;"></div>
    <div class="absolute -bottom-20 right-5 sm:right-10 w-72 sm:w-[500px] h-72 sm:h-[500px] bg-eco-600/10 dark:bg-eco-600/5 rounded-full blur-3xl sm:blur-[120px] animate-float" style="animation-duration: 8s; animation-delay: 1s;"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-4xl mx-auto text-center" x-data="{ show: false }" x-init="setTimeout(() => show = true, 200)">
    
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-3 sm:px-4 py-1.5 sm:py-2 rounded-full border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 backdrop-blur-md mb-6 sm:mb-8 transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]"
         :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
      <span class="w-2 h-2 rounded-full bg-eco-500 animate-pulse"></span>
      <span class="text-[10px] sm:text-xs font-bold uppercase tracking-widest text-black/70 dark:text-white/70">✨ Digital Sustainability Experts</span>
    </div>
    
    <!-- Heading -->
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-7xl font-black tracking-tighter leading-[1.2] text-black dark:text-white mb-3 sm:mb-6 transition-all duration-1000 delay-100 ease-[cubic-bezier(0.16,1,0.3,1)]"
        :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
      Premium Web.<br class="hidden sm:block">
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-eco-500 via-eco-400 to-emerald-400">Zero Carbon Impact.</span>
    </h1>
    
    <!-- Subheading -->
    <p class="text-base sm:text-lg md:text-xl text-black/60 dark:text-white/60 max-w-2xl mx-auto mb-8 sm:mb-10 leading-relaxed transition-all duration-1000 delay-200 ease-[cubic-bezier(0.16,1,0.3,1)]"
       :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
      We engineer premium web applications that elevate your brand and drastically reduce your digital carbon emissions through uncompromising code efficiency.
    </p>
    
    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-6 transition-all duration-1000 delay-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
         :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
      <a href="/#contact" class="w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 rounded-full bg-black dark:bg-white text-white dark:text-black font-bold text-sm sm:text-base hover:shadow-2xl hover:shadow-black/30 dark:hover:shadow-white/20 transform hover:scale-105 active:scale-95 transition-all duration-300">
        Request Estimate
      </a>
      <a href="#services" class="w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 rounded-full bg-transparent text-black dark:text-white font-bold text-sm sm:text-base border border-black/20 dark:border-white/20 hover:border-black dark:hover:border-white hover:bg-black/5 dark:hover:bg-white/5 transition-all flex items-center justify-center gap-2 group">
        Explore Services <i class='bx bx-right-arrow-alt text-lg group-hover:translate-x-1 transition-transform'></i>
      </a>
    </div>
  </div>
</section>

<!-- Services Section -->
<section id="services" class="py-16 sm:py-24 md:py-32 px-3 sm:px-6 lg:px-8 max-w-7xl mx-auto border-t border-black/5 dark:border-white/5 bg-white dark:bg-black">
  <div x-data="{ shown: false }" x-intersect.once.margin.-100px="shown = true">
    
    <!-- Section Header -->
    <div class="mb-10 sm:mb-16 md:mb-20 transition-all duration-1000 ease-out" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
      <h2 class="text-xs sm:text-sm font-bold tracking-widest uppercase text-eco-600 dark:text-eco-400 mb-2 sm:mb-3">Capabilities</h2>
      <h3 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter text-black dark:text-white">What We Do.</h3>
    </div>

    <!-- Services Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3 sm:gap-5">
      <% if (services && services.length > 0) { %>
        <% services.forEach((service, index) => { %>
          <div class="group bg-white dark:bg-[#0f0f0f] p-5 sm:p-7 rounded-2xl border border-black/8 dark:border-white/8 hover:border-black/15 dark:hover:border-white/12 hover:shadow-lg hover:shadow-black/5 dark:hover:shadow-eco-500/10 transition-all duration-500 backdrop-blur-sm"
               style="transition-delay: <%= index * 100 %>ms;"
               :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            
            <!-- Icon -->
            <div class="w-11 sm:w-12 h-11 sm:h-12 rounded-xl bg-gradient-to-br from-eco-50 to-eco-100 dark:from-eco-950 dark:to-eco-900 flex items-center justify-center mb-4 sm:mb-5 border border-eco-200 dark:border-eco-900 group-hover:from-eco-500 group-hover:to-eco-600 dark:group-hover:from-eco-500 dark:group-hover:to-eco-600 group-hover:border-eco-500 group-hover:shadow-lg group-hover:shadow-eco-500/20 transition-all duration-500">
              <i class='bx <%= service.iconClass %> text-lg sm:text-xl text-eco-600 dark:text-eco-400 group-hover:text-white transition-colors duration-500'></i>
            </div>
            
            <!-- Text -->
            <h4 class="text-base sm:text-lg font-bold text-black dark:text-white mb-2 tracking-tight"><%= service.name %></h4>
            <p class="text-black/60 dark:text-white/60 text-xs sm:text-sm leading-relaxed line-clamp-3"><%= service.description %></p>
          </div>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center text-black/40 dark:text-white/40 py-10 text-xs sm:text-sm font-medium">Services syncing from backend...</div>
      <% } %>
    </div>
  </div>
</section>

<!-- Portfolio Section -->
<section id="portfolio" class="py-16 sm:py-24 md:py-32 px-3 sm:px-6 lg:px-8 max-w-7xl mx-auto border-t border-black/5 dark:border-white/5 bg-white dark:bg-black">
  <div x-data="{ shown: false }" x-intersect.once.margin.-100px="shown = true">
    
    <!-- Section Header -->
    <div class="mb-10 sm:mb-16 md:mb-20 transition-all duration-1000 ease-out" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
      <h2 class="text-xs sm:text-sm font-bold tracking-widest uppercase text-eco-600 dark:text-eco-400 mb-2 sm:mb-3">Our Work</h2>
      <h3 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter text-black dark:text-white">Recent Projects.</h3>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 sm:gap-8 md:gap-12">
      <% if (projects && projects.length > 0) { %>
        <% projects.forEach((project, index) => { %>
          <a href="<%= project.projectUrl || '#' %>" target="_blank" rel="noopener noreferrer" class="group block transition-all duration-1000 ease-out" style="transition-delay: <%= index * 150 %>ms;" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-16'">
            
            <!-- Image -->
            <div class="relative overflow-hidden rounded-2xl sm:rounded-3xl aspect-[4/3] bg-black/5 dark:bg-white/5 mb-5 sm:mb-6 border border-black/10 dark:border-white/10 group-hover:border-black/20 dark:group-hover:border-white/20 transition-all duration-500">
              <% if (project.imageUrl) { %>
                <img src="<%= project.imageUrl %>" 
                     alt="<%= project.title %>" 
                     class="w-full h-full object-cover transform transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-110"
                     loading="lazy">
              <% } else { %>
                <div class="w-full h-full flex items-center justify-center text-black/20 dark:text-white/20">
                  <i class='bx bx-image-alt text-5xl sm:text-6xl'></i>
                </div>
              <% } %>
              
              <!-- Tech Stack Badge -->
              <div class="absolute bottom-4 sm:bottom-6 left-4 sm:left-6 flex flex-wrap gap-1.5 sm:gap-2 pointer-events-none">
                <% if(project.techStack) { project.techStack.split(',').slice(0, 3).forEach(tech => { %>
                  <span class="px-2.5 sm:px-3 py-1 text-[9px] sm:text-[10px] font-bold uppercase tracking-wider bg-white/95 dark:bg-black/90 backdrop-blur-md text-black dark:text-white rounded-full shadow-sm">
                    <%= tech.trim() %>
                  </span>
                <% }) } %>
              </div>
            </div>
            
            <!-- Content -->
            <div>
              <h4 class="text-lg sm:text-xl md:text-2xl font-bold tracking-tight text-black dark:text-white mb-2 sm:mb-3 flex items-center gap-2 group">
                <%= project.title %> 
                <i class='bx bx-right-top-arrow-circle text-black/30 dark:text-white/30 opacity-0 -translate-x-2 translate-y-2 group-hover:opacity-100 group-hover:translate-x-0 group-hover:translate-y-0 transition-all duration-300 text-base sm:text-lg'></i>
              </h4>
              <p class="text-black/60 dark:text-white/60 text-xs sm:text-sm leading-relaxed max-w-lg"><%= project.description %></p>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center text-black/40 dark:text-white/40 py-12 text-sm font-medium">Portfolio syncing from backend...</div>
      <% } %>
    </div>
  </div>
</section>

<!-- Blog Section -->
<section id="blog" class="py-16 sm:py-24 md:py-32 px-3 sm:px-6 lg:px-8 max-w-7xl mx-auto border-t border-black/5 dark:border-white/5 bg-white dark:bg-black">
  <div x-data="{ shown: false }" x-intersect.once.margin.-100px="shown = true">
    
    <!-- Section Header -->
    <div class="mb-10 sm:mb-16 md:mb-20 transition-all duration-1000 ease-out" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
      <h2 class="text-xs sm:text-sm font-bold tracking-widest uppercase text-eco-600 dark:text-eco-400 mb-2 sm:mb-3">Insights</h2>
      <h3 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter text-black dark:text-white">Journal.</h3>
    </div>

    <!-- Blog Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8">
      <% if (blogs && blogs.length > 0) { %>
        <% blogs.slice(0, 6).forEach((blog, index) => { %>
          <a href="/blog/<%= blog.slug %>" class="group block transition-all duration-1000 ease-out" style="transition-delay: <%= index * 100 %>ms;" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            
            <!-- Blog Card -->
            <div class="h-full flex flex-col p-6 sm:p-8 rounded-2xl sm:rounded-3xl border border-black/10 dark:border-white/10 bg-black/2 dark:bg-white/2 hover:border-black/20 dark:hover:border-white/20 hover:bg-black/5 dark:hover:bg-white/8 transition-all duration-500 backdrop-blur-sm group-hover:shadow-lg">
              
              <!-- Image -->
              <% if (blog.imageUrl) { %>
                <div class="relative overflow-hidden rounded-lg mb-4 sm:mb-6 aspect-video bg-black/5 dark:bg-white/5">
                  <img src="<%= blog.imageUrl %>" 
                       alt="<%= blog.title %>" 
                       class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-110"
                       loading="lazy">
                </div>
              <% } %>
              
              <!-- Content -->
              <div class="flex flex-col flex-grow">
                <!-- Category -->
                <div class="flex items-center gap-2 mb-3 sm:mb-4">
                  <span class="text-xs font-bold uppercase tracking-wider text-eco-600 dark:text-eco-400"><%= blog.category || 'Article' %></span>
                  <span class="text-black/30 dark:text-white/30">•</span>
                  <span class="text-xs text-black/50 dark:text-white/50"><%= new Date(blog.createdAt).toLocaleDateString() %></span>
                </div>
                
                <!-- Title -->
                <h4 class="text-base sm:text-lg font-bold text-black dark:text-white mb-2 sm:mb-3 group-hover:text-eco-600 transition-colors line-clamp-2"><%= blog.title %></h4>
                
                <!-- Description -->
                <p class="text-black/60 dark:text-white/60 text-xs sm:text-sm leading-relaxed flex-grow line-clamp-3 mb-4"><%= blog.excerpt || blog.description %></p>
                
                <!-- Read More -->
                <div class="flex items-center gap-2 text-eco-600 dark:text-eco-400 font-bold text-sm opacity-0 group-hover:opacity-100 transition-opacity">
                  Read More <i class='bx bx-right-arrow-alt'></i>
                </div>
              </div>
            </div>
          </a>
        <% }) %>
      <% } else { %>
        <div class="col-span-full text-center text-black/40 dark:text-white/40 py-12 text-sm font-medium">Blog posts syncing from backend...</div>
      <% } %>
    </div>

    <!-- View All Link -->
    <div class="flex justify-center mt-12 sm:mt-16">
      <a href="/blog" class="px-6 sm:px-8 py-3 sm:py-4 rounded-full border border-black/20 dark:border-white/20 text-black dark:text-white font-bold text-sm uppercase tracking-wide hover:border-black dark:hover:border-white hover:bg-black/5 dark:hover:bg-white/5 transition-all">
        View All Articles
      </a>
    </div>
  </div>
</section>

<!-- CTA Section -->
<section id="contact" class="py-16 sm:py-24 md:py-32 px-3 sm:px-6 lg:px-8 relative overflow-hidden bg-black dark:bg-black">
  
  <!-- Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute top-10 sm:top-20 left-1/2 -translate-x-1/2 w-96 sm:w-[500px] h-64 sm:h-[300px] bg-eco-500/8 dark:bg-eco-500/5 rounded-full blur-3xl sm:blur-[100px]"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-3xl mx-auto text-center text-white">
    <h2 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-black tracking-tighter mb-3 sm:mb-5">Ready to Go Green?</h2>
    <p class="text-sm sm:text-base md:text-lg text-white/60 max-w-xl mx-auto mb-6 sm:mb-8 leading-relaxed">Let&apos;s discuss how we can build your next project with sustainability and premium design at its core.</p>
    
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-6">
      <a href="mailto:hello@ecotechhub.com" class="w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 rounded-full bg-eco-500 hover:bg-eco-600 text-white font-bold text-sm sm:text-base uppercase tracking-wide transform hover:scale-105 active:scale-95 transition-all duration-300 shadow-lg shadow-eco-500/20">
        Get In Touch
      </a>
      <a href="#services" class="w-full sm:w-auto px-6 sm:px-8 py-3 sm:py-4 rounded-full border border-white/20 text-white font-bold text-sm sm:text-base uppercase tracking-wide hover:border-white hover:bg-white/10 transition-all">
        Learn More
      </a>
    </div>
  </div>
</section>
