<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden selection:bg-eco-500 selection:text-white">
    <div class="absolute top-0 right-0 -mr-20 -mt-20 w-96 h-96 rounded-full bg-eco-500/10 dark:bg-eco-500/5 blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-20 -mb-20 w-72 h-72 rounded-full bg-blue-500/10 dark:bg-blue-500/5 blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10 text-center" x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)">
        
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-eco-50 dark:bg-eco-900/30 text-eco-600 dark:text-eco-400 text-xs font-bold mb-8 uppercase tracking-widest border border-eco-100 dark:border-eco-800/50 shadow-sm transition-all duration-700 transform" :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            <span class="relative flex h-2 w-2">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-eco-400 opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2 w-2 bg-eco-500"></span>
            </span>
            Building the Sustainable Web
        </div>
        
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter text-gray-900 dark:text-white mb-8 leading-[1.1] transition-all duration-700 delay-100 transform" :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            High-End Web Dev.<br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-eco-500 to-blue-500">Zero Carbon Footprint.</span>
        </h1>
        
        <p class="mt-6 text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto mb-10 transition-all duration-700 delay-200 transform leading-relaxed" :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            We believe acquiring a website is an act of sustainable development. By writing ruthlessly efficient code and moving physical services online, we radically reduce emissions for you and your clients.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center gap-4 transition-all duration-700 delay-300 transform" :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            <a href="#contact" class="px-8 py-4 rounded-xl bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold text-lg hover:scale-105 transition-transform shadow-xl shadow-gray-900/20 dark:shadow-white/10">
                Request a Quote
            </a>
            <a href="#portfolio" class="px-8 py-4 rounded-xl bg-white dark:bg-gray-800 text-gray-900 dark:text-white font-bold text-lg border border-gray-200 dark:border-gray-700 hover:border-eco-500 dark:hover:border-eco-500 transition-colors flex items-center justify-center gap-2 group">
                View Our Work <i class='bx bx-right-arrow-alt text-xl group-hover:translate-x-1 transition-transform'></i>
            </a>
        </div>
    </div>
</section>

<section class="py-24 bg-white dark:bg-gray-900 border-y border-gray-100 dark:border-gray-800">
    <div class="max-w-7xl mx-auto px-6 lg:px-8" x-data="{ shown: false }" x-intersect.once="shown = true">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-12 lg:gap-16">
            
            <div class="transition-all duration-700 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                <div class="w-14 h-14 rounded-2xl bg-eco-50 dark:bg-eco-900/30 flex items-center justify-center text-eco-500 text-3xl mb-6 shadow-sm border border-eco-100 dark:border-eco-800/50">
                    <i class='bx bx-code-block'></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Efficient Architecture</h3>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed">Clean, lightweight code requires less server processing power, resulting in blazing-fast websites that consume significantly less electricity.</p>
            </div>

            <div class="transition-all duration-700 delay-100 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                <div class="w-14 h-14 rounded-2xl bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-blue-500 text-3xl mb-6 shadow-sm border border-blue-100 dark:border-blue-800/50">
                    <i class='bx bx-cloud'></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Digital Transformation</h3>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed">By moving physical processes to intuitive online services, your business radically reduces paper waste, physical infrastructure, and transport emissions.</p>
            </div>

            <div class="transition-all duration-700 delay-200 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                <div class="w-14 h-14 rounded-2xl bg-purple-50 dark:bg-purple-900/30 flex items-center justify-center text-purple-500 text-3xl mb-6 shadow-sm border border-purple-100 dark:border-purple-800/50">
                    <i class='bx bx-mobile-alt'></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-3">Uncompromising UX</h3>
                <p class="text-gray-600 dark:text-gray-400 leading-relaxed">Sustainability doesn't mean sacrifice. We deliver premium, highly-responsive designs with fluid animations that engage users flawlessly.</p>
            </div>

        </div>
    </div>
</section>

<section id="services" class="py-32 bg-gray-50 dark:bg-[#0b1120] relative">
    <div class="max-w-7xl mx-auto px-6 lg:px-8" x-data="{ shown: false }" x-intersect.once="shown = true">
        <div class="text-center max-w-3xl mx-auto mb-20 transition-all duration-700 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            <h2 class="text-eco-500 font-bold tracking-widest text-sm uppercase mb-3">Capabilities</h2>
            <h3 class="text-4xl md:text-5xl font-black text-gray-900 dark:text-white tracking-tight">Eco-Tech Solutions.</h3>
            <p class="mt-4 text-lg text-gray-600 dark:text-gray-400">Everything you need to digitize your operations sustainably.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (services && services.length > 0) { %>
                <% services.forEach((service, index) => { %>
                    <div class="group bg-white dark:bg-gray-800/80 p-8 rounded-3xl border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-xl transition-all duration-500 transform" 
                         style="transition-delay: <%= index * 100 %>ms;"
                         :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                        
                        <div class="w-16 h-16 rounded-2xl bg-gray-50 dark:bg-gray-900 flex items-center justify-center mb-8 border border-gray-100 dark:border-gray-700 group-hover:bg-eco-500 transition-colors duration-500">
                            <i class='bx <%= service.iconClass %> text-3xl text-gray-600 dark:text-gray-400 group-hover:text-white transition-colors duration-500'></i>
                        </div>
                        <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-3 group-hover:text-eco-500 transition-colors"><%= service.name %></h4>
                        <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed"><%= service.description %></p>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center text-gray-500 py-12">Services are currently being updated.</div>
            <% } %>
        </div>
    </div>
</section>

<section id="portfolio" class="py-32 bg-white dark:bg-gray-900 border-y border-gray-100 dark:border-gray-800">
    <div class="max-w-7xl mx-auto px-6 lg:px-8" x-data="{ shown: false }" x-intersect.once="shown = true">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 transition-all duration-700 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            <div class="max-w-2xl">
                <h2 class="text-blue-500 font-bold tracking-widest text-sm uppercase mb-3">Our Work</h2>
                <h3 class="text-4xl md:text-5xl font-black text-gray-900 dark:text-white tracking-tight">Recent Projects.</h3>
            </div>
            <a href="#" class="hidden md:flex items-center gap-2 font-bold text-gray-900 dark:text-white hover:text-blue-500 transition-colors group">
                View All Projects <i class='bx bx-right-arrow-alt text-xl group-hover:translate-x-1 transition-transform'></i>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">
            <% if (projects && projects.length > 0) { %>
                <% projects.forEach((project, index) => { %>
                    <a href="<%= project.projectUrl || '#' %>" target="_blank" class="group block transition-all duration-700 transform" style="transition-delay: <%= index * 150 %>ms;" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-16'">
                        <div class="relative overflow-hidden rounded-3xl aspect-[4/3] bg-gray-100 dark:bg-gray-800 mb-6 border border-gray-200 dark:border-gray-700">
                            <% if (project.imageUrl) { %>
                                <img src="<%= project.imageUrl %>" alt="<%= project.title %>" class="object-cover w-full h-full transform transition-transform duration-700 group-hover:scale-105">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-gray-400">
                                    <i class='bx bx-image-alt text-6xl'></i>
                                </div>
                            <% } %>
                            
                            <div class="absolute bottom-4 left-4 flex flex-wrap gap-2">
                                <% if(project.techStack) { project.techStack.split(',').forEach(tech => { %>
                                    <span class="px-3 py-1 text-[10px] font-bold uppercase tracking-wider bg-white/90 dark:bg-gray-900/90 backdrop-blur-md text-gray-900 dark:text-white rounded-full shadow-sm">
                                        <%= tech.trim() %>
                                    </span>
                                <% }) } %>
                            </div>
                            
                            <% if(project.isEcoFriendly) { %>
                                <div class="absolute top-4 right-4 w-8 h-8 bg-eco-500 rounded-full flex items-center justify-center text-white shadow-lg shadow-eco-500/30" title="Eco-Friendly Verified">
                                    <i class='bx bx-leaf'></i>
                                </div>
                            <% } %>
                        </div>
                        
                        <h4 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 group-hover:text-blue-500 transition-colors flex items-center gap-2">
                            <%= project.title %> <i class='bx bx-link-external opacity-0 group-hover:opacity-100 transition-opacity'></i>
                        </h4>
                        <p class="text-gray-600 dark:text-gray-400 line-clamp-2 leading-relaxed"><%= project.description %></p>
                    </a>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center text-gray-500 py-12">Portfolio is currently being updated.</div>
            <% } %>
        </div>
    </div>
</section>

<section id="blog" class="py-32 bg-gray-50 dark:bg-[#0b1120] relative overflow-hidden">
    <div class="absolute top-0 left-0 w-full h-full opacity-5 dark:opacity-10 pointer-events-none" style="background-image: radial-gradient(#10b981 1px, transparent 1px); background-size: 40px 40px;"></div>

    <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10" x-data="{ shown: false }" x-intersect.once="shown = true">
        <div class="text-center max-w-3xl mx-auto mb-20 transition-all duration-700 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            <h2 class="text-purple-500 font-bold tracking-widest text-sm uppercase mb-3">Insights</h2>
            <h3 class="text-4xl md:text-5xl font-black text-gray-900 dark:text-white tracking-tight">Sustainability Journal.</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach((blog, index) => { %>
                    <a href="/blog/<%= blog.slug %>" class="group block bg-white dark:bg-gray-800 rounded-3xl p-8 border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-xl transition-all duration-500 transform" style="transition-delay: <%= index * 100 %>ms;" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                        
                        <% 
                            let excerpt = "Read the full article...";
                            try {
                                const blocks = JSON.parse(blog.content);
                                const textBlock = blocks.find(b => b.type === 'intro' || b.type === 'paragraph');
                                if (textBlock && textBlock.content) {
                                    // Strip HTML tags for the preview
                                    excerpt = textBlock.content.replace(/<[^>]*>?/gm, '').substring(0, 120) + '...';
                                }
                            } catch(e) {}
                        %>

                        <div class="text-xs font-bold text-gray-400 dark:text-gray-500 mb-4 tracking-widest uppercase">
                            <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                        </div>
                        <h4 class="text-xl font-bold text-gray-900 dark:text-white mb-4 group-hover:text-purple-500 transition-colors leading-snug">
                            <%= blog.title %>
                        </h4>
                        <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed mb-6">
                            <%= excerpt %>
                        </p>
                        
                        <div class="flex items-center gap-2 text-sm font-bold text-gray-900 dark:text-white group-hover:text-purple-500 transition-colors mt-auto">
                            Read Article <i class='bx bx-right-arrow-alt text-xl group-hover:translate-x-1 transition-transform'></i>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center text-gray-500 py-12">No articles published yet.</div>
            <% } %>
        </div>
    </div>
</section>

<section id="contact" class="py-24 bg-eco-500 relative overflow-hidden">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
    <div class="max-w-4xl mx-auto px-6 lg:px-8 text-center relative z-10" x-data="{ shown: false }" x-intersect.once="shown = true">
        <h2 class="text-4xl md:text-6xl font-black text-white tracking-tight mb-6 transition-all duration-700 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            Ready to digitize your impact?
        </h2>
        <p class="text-eco-100 text-xl mb-10 max-w-2xl mx-auto transition-all duration-700 delay-100 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            Let's build a high-performance web solution that elevates your brand and respects our planet.
        </p>
        <div class="flex flex-col sm:flex-row justify-center gap-4 transition-all duration-700 delay-200 transform" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            <a href="/contact" class="px-8 py-4 rounded-xl bg-gray-900 text-white font-bold text-lg hover:scale-105 transition-transform shadow-xl shadow-gray-900/20">
                Get an Estimate
            </a>
            <a href="mailto:hello@ecotechhub.com" class="px-8 py-4 rounded-xl bg-transparent text-white font-bold text-lg border border-white/30 hover:bg-white/10 transition-colors">
                Email Us Directly
            </a>
        </div>
    </div>
</section>