<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden px-4 sm:px-6 lg:px-8 py-20 sm:py-32 bg-white dark:bg-black">
    <div class="absolute inset-0 pointer-events-none">
        <div class="absolute top-1/4 left-10 w-64 sm:w-96 h-64 sm:h-96 bg-eco-500/15 dark:bg-eco-500/8 rounded-full blur-3xl sm:blur-[100px] animate-float" style="animation-duration: 6s;"></div>
        <div class="absolute -bottom-20 right-5 sm:right-10 w-72 sm:w-[500px] h-72 sm:h-[500px] bg-blue-500/10 dark:bg-blue-500/5 rounded-full blur-3xl sm:blur-[120px] animate-float" style="animation-duration: 8s; animation-delay: 1s;"></div>
    </div>

    <div class="relative z-10 max-w-5xl mx-auto text-center" x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)">
        
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 backdrop-blur-md mb-8 transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]"
             :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            <span class="w-2 h-2 rounded-full bg-eco-500 animate-pulse"></span>
            <span class="text-xs font-bold uppercase tracking-widest text-black/70 dark:text-white/70">Digital Sustainability Experts</span>
        </div>
        
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black tracking-tighter leading-[1.05] text-black dark:text-white mb-6 transition-all duration-1000 delay-100 ease-[cubic-bezier(0.16,1,0.3,1)]"
            :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            Premium Web.<br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-eco-500 to-blue-400">Zero Carbon Impact.</span>
        </h1>
        
        <p class="text-lg sm:text-xl md:text-2xl text-black/60 dark:text-white/60 max-w-3xl mx-auto mb-12 leading-relaxed transition-all duration-1000 delay-200 ease-[cubic-bezier(0.16,1,0.3,1)]"
           :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            We engineer premium web applications that elevate your brand and drastically reduce your digital carbon emissions through uncompromising code efficiency.
        </p>
        
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-6 transition-all duration-1000 delay-300 ease-[cubic-bezier(0.16,1,0.3,1)]"
             :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            <a href="/contact" class="w-full sm:w-auto px-8 py-4 rounded-full bg-black dark:bg-white text-white dark:text-black font-bold text-sm sm:text-base hover:scale-105 transition-transform duration-300 shadow-xl shadow-black/20 dark:shadow-white/10">
                Request Estimate
            </a>
            <a href="/services" class="w-full sm:w-auto px-8 py-4 rounded-full bg-transparent text-black dark:text-white font-bold text-sm sm:text-base border border-black/20 dark:border-white/20 hover:border-black dark:hover:border-white transition-colors flex items-center justify-center gap-2 group">
                Explore Services <i class='bx bx-right-arrow-alt text-xl group-hover:translate-x-1 transition-transform'></i>
            </a>
        </div>
    </div>
</section>

<section id="services" class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 max-w-[1400px] mx-auto border-t border-black/5 dark:border-white/10 bg-white dark:bg-black">
    <div x-data="{ shown: false }" 
         x-intersect:enter="shown = true" 
         x-intersect:leave="shown = false">
        
        <div class="mb-16 md:mb-20 opacity-0 translate-y-12 transition-all duration-1000 ease-out" 
             :class="shown && '!opacity-100 !translate-y-0'">
            <h2 class="text-sm font-bold tracking-widest uppercase text-eco-500 mb-3">Capabilities</h2>
            <h3 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-black dark:text-white">What We Do.</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
            <% if (services && services.length > 0) { %>
                <% services.forEach((service, index) => { %>
                    <div class="group bg-black/5 dark:bg-[#0f0f0f] p-8 md:p-10 rounded-[2rem] border border-black/5 dark:border-white/5 hover:border-black/15 dark:hover:border-white/15 opacity-0 translate-y-12 transition-all duration-1000 ease-out"
                         style="transition-delay: <%= index * 100 %>ms;"
                         :class="shown && '!opacity-100 !translate-y-0'">
                        
                        <div class="w-14 h-14 rounded-2xl bg-white dark:bg-[#1a1a1a] flex items-center justify-center mb-8 border border-black/10 dark:border-white/10 group-hover:bg-eco-500 group-hover:border-eco-500 transition-colors duration-500 shadow-sm">
                            <i class='bx <%= service.iconClass %> text-2xl text-black dark:text-white group-hover:text-white transition-colors duration-500'></i>
                        </div>
                        
                        <h4 class="text-2xl font-bold tracking-tight text-black dark:text-white mb-4 group-hover:text-eco-500 transition-colors"><%= service.name %></h4>
                        <p class="text-black/60 dark:text-white/60 text-sm md:text-base leading-relaxed line-clamp-3"><%= service.description %></p>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center text-black/40 dark:text-white/40 py-12 text-sm font-medium">Services syncing from backend...</div>
            <% } %>
        </div>
    </div>
</section>

<section id="portfolio" class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 max-w-[1400px] mx-auto border-t border-black/5 dark:border-white/10 bg-white dark:bg-black">
    <div x-data="{ shown: false }" 
         x-intersect:enter="shown = true" 
         x-intersect:leave="shown = false">
        
        <div class="mb-16 md:mb-20 transition-all duration-1000 ease-out" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            <h2 class="text-sm font-bold tracking-widest uppercase text-blue-500 mb-3">Our Work</h2>
            <h3 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-black dark:text-white">Recent Projects.</h3>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-12">
            <% if (projects && projects.length > 0) { %>
                <% projects.forEach((project, index) => { %>
                    <a href="<%= project.projectUrl || '#' %>" target="_blank" rel="noopener noreferrer" class="group block transition-all duration-1000 ease-out" style="transition-delay: <%= index * 150 %>ms;" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-16'">
                        
                        <div class="relative overflow-hidden rounded-[2rem] aspect-[4/3] bg-black/5 dark:bg-[#0f0f0f] mb-6 border border-black/10 dark:border-white/10 group-hover:border-black/20 dark:group-hover:border-white/20 transition-all duration-500">
                            <% if (project.imageUrl) { %>
                                <img src="<%= project.imageUrl %>" 
                                     alt="<%= project.title %>" 
                                     class="w-full h-full object-cover transform transition-transform duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105"
                                     loading="lazy">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-black/20 dark:text-white/20">
                                    <i class='bx bx-image-alt text-6xl'></i>
                                </div>
                            <% } %>
                            
                            <div class="absolute bottom-6 left-6 flex flex-wrap gap-2 pointer-events-none">
                                <% if(project.techStack) { project.techStack.split(',').slice(0, 3).forEach(tech => { %>
                                    <span class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider bg-white/95 dark:bg-black/90 backdrop-blur-md text-black dark:text-white rounded-full shadow-sm">
                                        <%= tech.trim() %>
                                    </span>
                                <% }) } %>
                            </div>
                        </div>
                        
                        <div>
                            <h4 class="text-2xl md:text-3xl font-bold tracking-tight text-black dark:text-white mb-3 flex items-center gap-2 group-hover:text-blue-500 transition-colors">
                                <%= project.title %> 
                                <i class='bx bx-right-top-arrow-circle text-black/30 dark:text-white/30 opacity-0 -translate-x-2 translate-y-2 group-hover:opacity-100 group-hover:translate-x-0 group-hover:translate-y-0 transition-all duration-300'></i>
                            </h4>
                            <p class="text-black/60 dark:text-white/60 text-sm md:text-base leading-relaxed max-w-xl"><%= project.description %></p>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center text-black/40 dark:text-white/40 py-12 text-sm font-medium">Portfolio syncing from backend...</div>
            <% } %>
        </div>
    </div>
</section>

<section id="blog" class="py-24 md:py-32 px-4 sm:px-6 lg:px-8 max-w-[1400px] mx-auto border-t border-black/5 dark:border-white/10 bg-white dark:bg-black">
    <div x-data="{ shown: false }" 
         x-intersect:enter="shown = true" 
         x-intersect:leave="shown = false">
        
        <div class="mb-16 md:mb-20 transition-all duration-1000 ease-out" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            <h2 class="text-sm font-bold tracking-widest uppercase text-purple-500 mb-3">Insights</h2>
            <h3 class="text-4xl md:text-5xl lg:text-6xl font-black tracking-tighter text-black dark:text-white">Sustainability Journal.</h3>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% if (blogs && blogs.length > 0) { %>
                <% blogs.forEach((blog, index) => { %>
                    <% 
                        let excerpt = "Read the full publication...";
                        try {
                            const blocks = JSON.parse(blog.content);
                            const textBlock = blocks.find(b => b.type === 'intro' || b.type === 'paragraph');
                            if (textBlock && textBlock.content) {
                                excerpt = textBlock.content.replace(/<[^>]*>?/gm, '').substring(0, 120) + '...';
                            }
                        } catch(e) {}
                    %>

                    <a href="/blog/<%= blog.slug %>" class="group block transition-all duration-1000 ease-out" style="transition-delay: <%= index * 100 %>ms;" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
                        <div class="h-full flex flex-col p-8 rounded-[2rem] border border-black/10 dark:border-white/10 bg-black/5 dark:bg-[#0f0f0f] hover:border-black/20 dark:hover:border-white/20 transition-all duration-500">
                            
                            <div class="flex items-center gap-4 mb-6">
                                <span class="px-3 py-1 rounded-full bg-white dark:bg-black border border-black/10 dark:border-white/10 text-[10px] font-bold uppercase tracking-widest text-black/60 dark:text-white/60">
                                    Article
                                </span>
                                <span class="text-xs font-bold text-black/40 dark:text-white/40 uppercase tracking-widest">
                                    <%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                                </span>
                            </div>

                            <h4 class="text-xl md:text-2xl font-bold text-black dark:text-white mb-4 group-hover:text-purple-500 transition-colors leading-[1.2]"><%= blog.title %></h4>
                            
                            <p class="text-black/60 dark:text-white/60 text-sm md:text-base leading-relaxed flex-grow mb-6"><%= excerpt %></p>
                            
                            <div class="flex items-center gap-2 font-bold text-sm uppercase tracking-widest text-black dark:text-white group-hover:text-purple-500 transition-colors mt-auto">
                                Read More <i class='bx bx-right-arrow-alt text-xl group-hover:translate-x-2 transition-transform'></i>
                            </div>
                        </div>
                    </a>
                <% }) %>
            <% } else { %>
                <div class="col-span-full text-center text-black/40 dark:text-white/40 py-12 text-sm font-medium">Journal entries syncing from backend...</div>
            <% } %>
        </div>
        
        <div class="mt-16 text-center">
            <a href="/blog" class="inline-block px-8 py-4 rounded-full border border-black/20 dark:border-white/20 text-black dark:text-white font-bold text-sm uppercase tracking-widest hover:border-black dark:hover:border-white hover:bg-black/5 dark:hover:bg-white/5 transition-all">
                View All Publications
            </a>
        </div>
    </div>
</section>

<section class="py-32 px-4 relative overflow-hidden bg-eco-500 border-t border-black/10 dark:border-white/10">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
    <div class="max-w-4xl mx-auto text-center relative z-10" x-data="{ shown: false }" x-intersect.once="shown = true">
        <h2 class="text-4xl md:text-6xl font-black tracking-tighter text-white mb-6 transition-all duration-700" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            Ready to Digitize Your Impact?
        </h2>
        <p class="text-lg md:text-xl text-eco-50 max-w-2xl mx-auto mb-10 leading-relaxed transition-all duration-700 delay-100" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            Let's build a high-performance web solution that elevates your brand and respects our planet.
        </p>
        <div class="flex flex-col sm:flex-row justify-center items-center gap-4 transition-all duration-700 delay-200" :class="shown ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            <a href="/contact" class="w-full sm:w-auto px-8 py-4 rounded-full bg-black text-white font-bold text-sm md:text-base hover:scale-105 transition-transform shadow-xl">
                Get an Estimate
            </a>
        </div>
    </div>
</section>