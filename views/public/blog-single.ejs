<article class="relative pt-32 pb-24 md:pt-48 md:pb-32 px-4 sm:px-6 lg:px-8 max-w-[1000px] mx-auto overflow-hidden">
    
    <div class="fixed top-0 left-1/2 -translate-x-1/2 w-[800px] h-[500px] rounded-full bg-purple-500/5 dark:bg-purple-500/5 blur-[120px] pointer-events-none -z-10"></div>

    <div x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)">
        
        <div class="mb-12 transition-all duration-700 ease-out transform" :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-8'">
            <a href="/blog" class="inline-flex items-center gap-2 text-sm font-bold uppercase tracking-widest text-black/50 dark:text-white/50 hover:text-purple-500 dark:hover:text-purple-400 transition-colors mb-8">
                <i class='bx bx-left-arrow-alt text-xl'></i> Back to Journal
            </a>
            
            <div class="flex items-center gap-4 text-xs font-bold uppercase tracking-widest text-black/40 dark:text-white/40 mb-6">
                <span class="px-3 py-1 rounded-full border border-black/10 dark:border-white/10 bg-black/5 dark:bg-white/5 backdrop-blur-md">Publication</span>
                <span><%= new Date(blog.createdAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }) %></span>
            </div>
            
            <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black tracking-tighter text-black dark:text-white leading-[1.05]">
                <%= blog.title %>
            </h1>
        </div>

        <hr class="border-black/10 dark:border-white/10 mb-16 transition-all duration-700 delay-100 transform" :class="show ? 'opacity-100' : 'opacity-0'">

        <div class="prose prose-lg dark:prose-invert max-w-3xl mx-auto font-medium text-black/70 dark:text-white/70 leading-relaxed transition-all duration-1000 delay-200 transform" :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            
            <% 
                let blocks = [];
                try { blocks = JSON.parse(blog.content); } catch(e) { console.error('Failed to parse blog blocks'); }
            %>

            <% blocks.forEach(block => { %>
                
                <% if (block.type === 'intro') { %>
                    <div class="text-2xl md:text-3xl font-bold text-black dark:text-white leading-snug mb-12">
                        <%- block.content %>
                    </div>
                <% } %>

                <% if (block.type === 'paragraph') { %>
                    <div class="mb-12">
                        <% if (block.subheading) { %>
                            <h2 class="text-2xl font-bold tracking-tight text-black dark:text-white mb-4 mt-8"><%= block.subheading %></h2>
                        <% } %>
                        <div class="quill-content mb-6">
                            <%- block.content %>
                        </div>

                        <% if (block.attachments && block.attachments.length > 0) { %>
                            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-8 mb-12 not-prose">
                                <% block.attachments.forEach(att => { %>
                                    
                                    <% if (att.type === 'image' && att.url) { %>
                                        <div class="col-span-full rounded-3xl overflow-hidden bg-black/5 dark:bg-[#111111] border border-black/10 dark:border-white/10">
                                            <img src="<%= att.url %>" alt="<%= att.label %>" class="w-full h-auto object-cover">
                                        </div>
                                    <% } %>

                                    <% if (att.type === 'service' || att.type === 'project') { %>
                                        <a href="<%= att.type === 'service' ? '/services' : '/projects' %>" class="flex items-center gap-4 p-4 rounded-2xl bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 hover:border-black/30 dark:hover:border-white/30 transition-colors group">
                                            <div class="w-12 h-12 rounded-full bg-white dark:bg-black flex items-center justify-center border border-black/10 dark:border-white/10 group-hover:bg-eco-500 transition-colors duration-300">
                                                <i class='bx <%= att.type === 'project' ? 'bx-folder text-green-500' : 'bx-layer text-blue-500' %> text-xl group-hover:text-white transition-colors duration-300'></i>
                                            </div>
                                            <div>
                                                <div class="text-[10px] font-bold uppercase tracking-widest text-black/40 dark:text-white/40 mb-0.5">Linked <%= att.type %></div>
                                                <div class="font-bold text-black dark:text-white text-sm"><%= att.label %></div>
                                            </div>
                                        </a>
                                    <% } %>
                                    
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                <% } %>

                <% if (block.type === 'quote') { %>
                    <blockquote class="relative p-8 md:p-10 my-16 rounded-[2rem] bg-purple-500/5 dark:bg-purple-500/10 border border-purple-500/20 dark:border-purple-500/20 not-prose">
                        <i class='bx bxs-quote-alt-left text-4xl text-purple-500/50 absolute top-6 left-6'></i>
                        <div class="relative z-10 text-xl md:text-2xl font-bold text-black dark:text-white italic leading-relaxed text-center">
                            <%- block.content.replace(/<[^>]*>?/gm, '') %>
                        </div>
                    </blockquote>
                <% } %>

                <% if (block.type === 'conclusion') { %>
                    <div class="mt-16 pt-12 border-t border-black/10 dark:border-white/10">
                        <% if (block.subheading) { %>
                            <h2 class="text-2xl font-bold tracking-tight text-black dark:text-white mb-4"><%= block.subheading %></h2>
                        <% } %>
                        <div class="quill-content text-lg">
                            <%- block.content %>
                        </div>
                    </div>
                <% } %>

            <% }) %>
        </div>
    </div>
</article>

<style>
    .quill-content p { margin-bottom: 1.5em; }
    .quill-content a { color: #10b981; text-decoration: underline; font-weight: bold; }
    .quill-content ul { list-style-type: disc; padding-left: 1.5em; margin-bottom: 1.5em; }
    .quill-content ol { list-style-type: decimal; padding-left: 1.5em; margin-bottom: 1.5em; }
</style>