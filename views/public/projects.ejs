<section class="relative pt-40 pb-16 md:pt-48 md:pb-24 px-4 sm:px-6 lg:px-8 max-w-[1400px] mx-auto text-center overflow-hidden">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] rounded-full bg-blue-500/10 dark:bg-blue-500/10 blur-[100px] pointer-events-none"></div>
    
    <div class="relative z-10" x-data="{ show: false }" x-init="setTimeout(() => show = true, 100)">
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-black tracking-tighter text-black dark:text-white mb-6 transition-all duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)]"
            :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            Our <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-eco-500">Portfolio.</span>
        </h1>
        <p class="text-lg md:text-xl text-black/60 dark:text-white/60 max-w-2xl mx-auto transition-all duration-1000 delay-100 ease-[cubic-bezier(0.16,1,0.3,1)]"
           :class="show ? 'opacity-100 translate-y-0' : 'opacity-0 translate-y-12'">
            Explore our latest high-performance, low-carbon digital products. Filter by technology or eco-credentials below.
        </p>
    </div>
</section>

<section class="pb-32 px-4 sm:px-6 lg:px-8 max-w-[1400px] mx-auto" x-data="portfolioFilter()">
    
    <div class="flex flex-wrap justify-center gap-2 mb-16 relative z-20">
        <button @click="setFilter('all')" 
                class="px-5 py-2.5 rounded-full text-sm font-bold tracking-wide transition-all duration-300 border backdrop-blur-md"
                :class="activeFilter === 'all' ? 'bg-black dark:bg-white text-white dark:text-black border-black dark:border-white shadow-lg' : 'bg-black/5 dark:bg-white/5 text-black/60 dark:text-white/60 border-black/10 dark:border-white/10 hover:border-black/30 dark:hover:border-white/30'">
            All Projects
        </button>
        
        <button @click="setFilter('eco')" 
                class="px-5 py-2.5 rounded-full text-sm font-bold tracking-wide transition-all duration-300 border backdrop-blur-md flex items-center gap-2"
                :class="activeFilter === 'eco' ? 'bg-eco-500 text-white border-eco-500 shadow-lg shadow-eco-500/20' : 'bg-black/5 dark:bg-white/5 text-eco-600 dark:text-eco-400 border-black/10 dark:border-white/10 hover:border-eco-500/50'">
            <i class='bx bx-leaf'></i> Eco-Verified
        </button>

        <% techStacks.forEach(tech => { %>
            <button @click="setFilter('<%= tech %>')" 
                    class="px-5 py-2.5 rounded-full text-sm font-bold tracking-wide transition-all duration-300 border backdrop-blur-md"
                    :class="activeFilter === '<%= tech %>' ? 'bg-black dark:bg-white text-white dark:text-black border-black dark:border-white shadow-lg' : 'bg-black/5 dark:bg-white/5 text-black/60 dark:text-white/60 border-black/10 dark:border-white/10 hover:border-black/30 dark:hover:border-white/30'">
                <%= tech %>
            </button>
        <% }) %>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-10">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach((project, index) => { %>
                <div x-show="matchesFilter('<%= project.techStack %>', <%= project.isEcoFriendly %>)" 
                     x-transition:enter="transition ease-out duration-500"
                     x-transition:enter-start="opacity-0 scale-95"
                     x-transition:enter-end="opacity-100 scale-100"
                     x-transition:leave="transition ease-in duration-300"
                     x-transition:leave-start="opacity-100 scale-100"
                     x-transition:leave-end="opacity-0 scale-95"
                     class="group block">
                     
                    <a href="<%= project.projectUrl || '#' %>" target="_blank" class="block">
                        <div class="relative overflow-hidden rounded-[2rem] aspect-[4/3] bg-black/5 dark:bg-[#111111] mb-6 border border-black/10 dark:border-white/10">
                            <% if (project.imageUrl) { %>
                                <img src="<%= project.imageUrl %>" alt="<%= project.title %>" class="object-cover w-full h-full transform transition-transform duration-1000 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-105">
                            <% } else { %>
                                <div class="w-full h-full flex items-center justify-center text-black/20 dark:text-white/20">
                                    <i class='bx bx-image-alt text-6xl'></i>
                                </div>
                            <% } %>
                            
                            <div class="absolute bottom-6 left-6 flex flex-wrap gap-2 pointer-events-none">
                                <% if(project.techStack) { project.techStack.split(',').forEach(tech => { %>
                                    <span class="px-3 py-1.5 text-[10px] font-bold uppercase tracking-wider bg-white/90 dark:bg-black/90 backdrop-blur-md text-black dark:text-white rounded-full shadow-sm">
                                        <%= tech.trim() %>
                                    </span>
                                <% }) } %>
                            </div>

                            <% if(project.isEcoFriendly) { %>
                                <div class="absolute top-4 right-4 w-10 h-10 bg-eco-500/90 backdrop-blur-md rounded-full flex items-center justify-center text-white shadow-lg" title="Eco-Friendly Verified">
                                    <i class='bx bx-leaf text-xl'></i>
                                </div>
                            <% } %>
                        </div>
                        
                        <h4 class="text-2xl font-bold tracking-tight text-black dark:text-white mb-3 flex items-center gap-2 group-hover:text-blue-500 transition-colors">
                            <%= project.title %> <i class='bx bx-right-top-arrow-circle text-black/40 dark:text-white/40 opacity-0 -translate-x-2 translate-y-2 group-hover:opacity-100 group-hover:translate-x-0 group-hover:translate-y-0 transition-all duration-300'></i>
                        </h4>
                        <p class="text-black/60 dark:text-white/60 text-sm leading-relaxed line-clamp-3"><%= project.description %></p>
                    </a>
                </div>
            <% }) %>
        <% } else { %>
            <div class="col-span-full text-center text-black/40 dark:text-white/40 py-20 font-medium">No projects available yet.</div>
        <% } %>
    </div>
</section>

<script>
// Alpine.js Logic for instant client-side filtering
function portfolioFilter() {
    return {
        activeFilter: 'all',
        setFilter(filter) {
            this.activeFilter = filter;
        },
        matchesFilter(techStack, isEcoFriendly) {
            if (this.activeFilter === 'all') return true;
            if (this.activeFilter === 'eco' && isEcoFriendly) return true;
            
            // Check if the project's tech stack includes the active filter
            if (techStack) {
                const stacks = techStack.split(',').map(s => s.trim());
                return stacks.includes(this.activeFilter);
            }
            return false;
        }
    }
}
</script>