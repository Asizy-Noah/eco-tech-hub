<div class="max-w-4xl mx-auto">
    <div class="mb-8">
        <a href="/admin/projects" class="text-sm text-eco-500 hover:text-eco-600 flex items-center gap-1 mb-2 transition-colors w-max">
            <i class='bx bx-left-arrow-alt'></i> Back to Projects
        </a>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Publish New Project</h1>
    </div>

    <form x-data="projectForm()" @submit.prevent="submitProject" class="bg-white dark:bg-eco-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 space-y-6">
        
        <div x-show="error" x-transition x-cloak class="p-4 bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 rounded-xl text-sm flex items-center gap-2">
            <i class='bx bx-error-circle text-lg'></i>
            <span x-text="error"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="col-span-2 md:col-span-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Project Title</label>
                <input type="text" x-model="formData.title" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none transition-all text-gray-900 dark:text-white">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Tech Stack</label>
                <input type="text" x-model="formData.techStack" placeholder="e.g. NestJS, Tailwind, SQLite" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none transition-all text-gray-900 dark:text-white">
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Project URL (Optional)</label>
                <input type="url" x-model="formData.projectUrl" placeholder="https://" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none transition-all text-gray-900 dark:text-white">
            </div>
            
            <div class="col-span-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Image URL</label>
                <input type="url" x-model="formData.imageUrl" placeholder="https://" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none transition-all text-gray-900 dark:text-white">
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Project Description</label>
                <textarea x-model="formData.description" rows="5" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none transition-all text-gray-900 dark:text-white"></textarea>
            </div>

            <div class="col-span-2 flex items-center gap-3 p-4 bg-eco-50 dark:bg-eco-900/30 rounded-xl border border-eco-100 dark:border-eco-800">
                <input type="checkbox" id="eco" x-model="formData.isEcoFriendly" class="w-5 h-5 text-eco-500 rounded border-gray-300 focus:ring-eco-500 bg-white">
                <label for="eco" class="text-sm font-medium text-eco-800 dark:text-eco-400 cursor-pointer">Mark as Climate-Friendly / Sustainable Development</label>
            </div>
        </div>

        <div class="pt-6 border-t border-gray-100 dark:border-gray-700 flex justify-end">
            <button type="submit" :disabled="loading" class="bg-eco-500 hover:bg-eco-600 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-lg shadow-eco-500/30 flex items-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed">
                <span x-show="!loading">Save Project</span>
                <i x-show="loading" class='bx bx-loader-alt animate-spin text-xl' x-cloak></i>
                <span x-show="loading" x-cloak>Saving...</span>
            </button>
        </div>
    </form>
</div>

<script>
function projectForm() {
    return {
        formData: {
            title: '',
            techStack: '',
            imageUrl: '',
            projectUrl: '',
            description: '',
            isEcoFriendly: true // Defaults to true for Eco Tech Hub!
        },
        loading: false,
        error: '',
        async submitProject() {
            this.loading = true;
            this.error = '';
            try {
                // Posts to the ProjectApiController you built
                const res = await fetch('/api/projects', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.formData)
                });
                
                if (!res.ok) throw new Error('Failed to save project. Please check your inputs.');
                
                // Redirect back to the table on success
                window.location.href = '/admin/projects';
            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        }
    }
}
</script>