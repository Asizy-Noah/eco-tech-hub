<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Eco Services</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage the solutions and capabilities you offer.</p>
    </div>
    <a href="/admin/services/new" class="bg-eco-500 hover:bg-eco-600 text-white px-4 py-2 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
        <i class='bx bx-plus text-xl'></i> Add Service
    </a>
</div>

<div class="bg-white dark:bg-eco-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-200 dark:border-gray-700">
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider w-16">Icon</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Service Name</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider w-1/2">Description</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (services.length === 0) { %>
                    <tr>
                        <td colspan="4" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                            <i class='bx bx-layer text-4xl mb-3 text-gray-300 dark:text-gray-600'></i>
                            <p>No services found. Add your first capability.</p>
                        </td>
                    </tr>
                <% } else { %>
                    <% services.forEach(service => { %>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="w-10 h-10 rounded-lg bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-blue-500 dark:text-blue-400 text-xl border border-blue-100 dark:border-blue-800">
                                    <i class='bx <%= service.iconClass %>'></i>
                                </div>
                            </td>
                            <td class="px-6 py-4 font-medium text-gray-900 dark:text-white">
                                <%= service.name %>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">
                                <%= service.description %>
                            </td>
                            <td class="px-6 py-4 text-right space-x-3">
                                <a href="/admin/services/edit/<%= service.id %>" class="text-gray-400 hover:text-blue-500 transition-colors" title="Edit Service">
                                    <i class='bx bx-edit text-xl'></i>
                                </a>
                                <button x-data @click="if(confirm('Are you sure you want to delete this service?')) { fetch('/api/services/<%= service.id %>', { method: 'DELETE' }).then(() => window.location.reload()) }" class="text-gray-400 hover:text-red-500 transition-colors" title="Delete Service">
                                    <i class='bx bx-trash text-xl'></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>