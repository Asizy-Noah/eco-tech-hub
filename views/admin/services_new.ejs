<div class="max-w-3xl mx-auto">
    <div class="mb-8">
        <a href="/admin/services" class="text-sm text-blue-500 hover:text-blue-600 flex items-center gap-1 mb-2">
            <i class='bx bx-left-arrow-alt'></i> Back to Services
        </a>
        <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Add Capability</h1>
    </div>

    <form x-data="serviceForm()" @submit.prevent="submit" class="bg-white dark:bg-eco-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 space-y-6">
        
        <div x-show="error" x-cloak class="p-4 bg-red-50 border-red-200 text-red-600 rounded-xl text-sm flex gap-2">
            <i class='bx bx-error-circle text-lg'></i><span x-text="error"></span>
        </div>

        <div class="space-y-6">
            <div>
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Service Name</label>
                <input type="text" x-model="formData.name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 outline-none">
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Boxicon Class (Live Preview)</label>
                <div class="flex items-center gap-4">
                    <div class="w-14 h-14 rounded-xl bg-blue-50 dark:bg-blue-900/30 flex items-center justify-center text-blue-500 dark:text-blue-400 text-3xl shrink-0 border border-blue-100 dark:border-blue-800">
                        <i class='bx' :class="formData.iconClass"></i>
                    </div>
                    <input type="text" x-model="formData.iconClass" placeholder="e.g. bx-leaf, bx-server, bx-code" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 outline-none">
                </div>
                <p class="text-xs text-gray-500 mt-2">Find icons at <a href="https://boxicons.com/" target="_blank" class="text-blue-500 hover:underline">Boxicons</a></p>
            </div>

            <div>
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Description</label>
                <textarea x-model="formData.description" rows="4" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-blue-500 outline-none"></textarea>
            </div>
        </div>

        <div class="pt-6 border-t border-gray-100 dark:border-gray-700 flex justify-end">
            <button type="submit" :disabled="loading" class="bg-eco-500 hover:bg-eco-600 text-white font-bold py-3 px-8 rounded-xl shadow-lg flex items-center gap-2">
                <span x-show="!loading">Save Service</span>
                <i x-show="loading" class='bx bx-loader-alt animate-spin text-xl' x-cloak></i>
            </button>
        </div>
    </form>
</div>

<script>
function serviceForm() {
    return {
        formData: { name: '', iconClass: 'bx-layer', description: '' },
        loading: false,
        error: '',
        async submit() {
            this.loading = true;
            this.error = '';
            try {
                const res = await fetch('/api/services', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(this.formData)
                });
                if (!res.ok) throw new Error('Failed to save service');
                window.location.href = '/admin/services';
            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        }
    }
}
</script>