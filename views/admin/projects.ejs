<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Projects</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage your portfolio and eco-tech case studies.</p>
    </div>
    <a href="/admin/projects/new" class="bg-eco-500 hover:bg-eco-600 text-white px-4 py-2 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
        <i class='bx bx-plus text-xl'></i> Add Project
    </a>
</div>

<div class="bg-white dark:bg-eco-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="bg-gray-50 dark:bg-gray-900/50 border-b border-gray-200 dark:border-gray-700">
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Project Title</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Tech Stack</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Status</th>
                    <th class="px-6 py-4 text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Date Added</th>
                    <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
                <% if (projects.length === 0) { %>
                    <tr>
                        <td colspan="5" class="px-6 py-12 text-center text-gray-500 dark:text-gray-400">
                            <i class='bx bx-folder-open text-4xl mb-3 text-gray-300 dark:text-gray-600'></i>
                            <p>No projects found. Start building your sustainable portfolio.</p>
                        </td>
                    </tr>
                <% } else { %>
                    <% projects.forEach(project => { %>
                        <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors group">
                            <td class="px-6 py-4">
                                <div class="font-medium text-gray-900 dark:text-white"><%= project.title %></div>
                                <% if (project.projectUrl) { %>
                                    <a href="<%= project.projectUrl %>" target="_blank" class="text-xs text-blue-500 hover:underline mt-1 inline-block"><%= project.projectUrl %></a>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-600 dark:text-gray-300">
                                <%= project.techStack %>
                            </td>
                            <td class="px-6 py-4">
                                <% if (project.isEcoFriendly) { %>
                                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400 border border-green-200 dark:border-green-800">
                                        <i class='bx bx-leaf'></i> Eco-Friendly
                                    </span>
                                <% } else { %>
                                    <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800 dark:bg-gray-800 dark:text-gray-300 border border-gray-200 dark:border-gray-700">
                                        Standard
                                    </span>
                                <% } %>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-500 dark:text-gray-400">
                                <%= new Date(project.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                            </td>
                            <td class="px-6 py-4 text-right space-x-3">
                                <a href="/admin/projects/edit/<%= project.id %>" class="text-gray-400 hover:text-eco-500 dark:hover:text-eco-neon transition-colors" title="Edit Project">
                                    <i class='bx bx-edit text-xl'></i>
                                </a>
                                <button x-data @click="if(confirm('Delete?')) fetch('/api/projects/<%= project.id %>', { method: 'DELETE' }).then(() => window.location.reload())" 
                                    class="text-gray-400 hover:text-red-500">
                                    <i class='bx bx-trash'></i>
                                </button>
                            </td>
                        </tr>
                    <% }) %>
                <% } %>
            </tbody>
        </table>
    </div>
</div>