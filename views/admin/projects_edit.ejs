<div class="max-w-4xl mx-auto">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <a href="/admin/projects" class="text-sm text-eco-500 hover:text-eco-600 flex items-center gap-1 mb-2">
                <i class='bx bx-left-arrow-alt'></i> Back to Projects
            </a>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Edit Project</h1>
        </div>
        <% if (project.imageUrl) { %>
            <img src="<%= project.imageUrl %>" alt="Current Image" class="h-16 w-16 object-cover rounded-xl shadow-sm border border-gray-200 dark:border-gray-700">
        <% } %>
    </div>

    <form x-data="editForm()" @submit.prevent="submit" class="bg-white dark:bg-eco-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 p-8 space-y-6">
        
        <div x-show="error" x-cloak class="p-4 bg-red-50 border-red-200 text-red-600 rounded-xl text-sm flex gap-2">
            <i class='bx bx-error-circle text-lg'></i><span x-text="error"></span>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="col-span-2 md:col-span-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Project Title</label>
                <input type="text" x-model="formData.title" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none">
            </div>

            <div class="col-span-2 md:col-span-1">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Tech Stack</label>
                <input type="text" x-model="formData.techStack" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none">
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Update Image (Leave blank to keep current)</label>
                <input type="file" x-ref="imageInput" accept="image/*" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-eco-50 file:text-eco-700 hover:file:bg-eco-100">
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Project URL</label>
                <input type="url" x-model="formData.projectUrl" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none">
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-2">Description</label>
                <textarea x-model="formData.description" rows="5" required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 focus:ring-2 focus:ring-eco-500 outline-none"></textarea>
            </div>

            <div class="col-span-2 flex items-center gap-3 p-4 bg-eco-50 dark:bg-eco-900/30 rounded-xl border border-eco-100 dark:border-eco-800">
                <input type="checkbox" id="eco" x-model="formData.isEcoFriendly" class="w-5 h-5 text-eco-500 rounded focus:ring-eco-500">
                <label for="eco" class="text-sm font-medium text-eco-800 dark:text-eco-400">Mark as Climate-Friendly</label>
            </div>
        </div>

        <div class="pt-6 border-t border-gray-100 dark:border-gray-700 flex justify-end">
            <button type="submit" :disabled="loading" class="bg-eco-500 hover:bg-eco-600 text-white font-bold py-3 px-8 rounded-xl shadow-lg flex items-center gap-2">
                <span x-show="!loading">Update Project</span>
                <i x-show="loading" class='bx bx-loader-alt animate-spin text-xl' x-cloak></i>
            </button>
        </div>
    </form>
</div>

<script>
function editForm() {
    return {
        formData: {
            // Using JSON.stringify ensures newlines in descriptions don't break JS
            title: `<%- project.title %>`,
            techStack: `<%- project.techStack %>`,
            projectUrl: `<%- project.projectUrl || '' %>`,
            description: `<%- project.description.replace(/`/g, '\\`').replace(/\n/g, '\\n') %>`,
            isEcoFriendly: <%= project.isEcoFriendly %>
        },
        loading: false,
        error: '',
        async submit() {
            this.loading = true;
            this.error = '';
            
            // Build FormData to allow file upload
            const data = new FormData();
            data.append('title', this.formData.title);
            data.append('techStack', this.formData.techStack);
            data.append('projectUrl', this.formData.projectUrl);
            data.append('description', this.formData.description);
            data.append('isEcoFriendly', this.formData.isEcoFriendly);

            // Grab the file if the user selected one
            const file = this.$refs.imageInput.files[0];
            if (file) {
                data.append('image', file);
            }

            try {
                // Notice we do NOT set 'Content-Type'. The browser sets it automatically with the boundary for multipart/form-data
                const res = await fetch('/api/projects/<%= project.id %>', {
                    method: 'PUT',
                    body: data
                });
                
                if (!res.ok) throw new Error('Update failed');
                window.location.href = '/admin/projects';
            } catch (err) {
                this.error = err.message;
            } finally {
                this.loading = false;
            }
        }
    }
}
</script>