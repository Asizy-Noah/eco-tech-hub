<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Login | Eco Tech Hub</title>
    <link href="/css/style.css" rel="stylesheet">
    <link href='https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css' rel='stylesheet'>
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <style>[x-cloak] { display: none !important; }</style>
</head>
<body class="bg-gray-50 flex items-center justify-center h-screen">

    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-8 border border-gray-100">
        <div class="text-center mb-8">
            <i class='bx bx-leaf text-eco-500 text-5xl mb-2'></i>
            <h2 class="text-2xl font-bold text-gray-900">Admin Portal</h2>
            <p class="text-gray-500 text-sm mt-1">Sign in to manage Eco Tech Hub</p>
        </div>

        <form x-data="loginForm()" @submit.prevent="submitAuth" class="space-y-6">
            
            <div x-show="errorMessage" x-transition x-cloak class="p-3 bg-red-50 border border-red-200 text-red-600 rounded-lg text-sm flex items-center gap-2">
                <i class='bx bx-error-circle text-lg'></i>
                <span x-text="errorMessage"></span>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class='bx bx-envelope text-gray-400 text-lg'></i>
                    </div>
                    <input type="email" x-model="email" required class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-eco-500 focus:border-eco-500 outline-none transition-shadow" placeholder="admin@ecotechhub.com">
                </div>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class='bx bx-lock-alt text-gray-400 text-lg'></i>
                    </div>
                    <input type="password" x-model="password" required class="w-full pl-10 pr-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-eco-500 focus:border-eco-500 outline-none transition-shadow" placeholder="••••••••">
                </div>
            </div>

            <button type="submit" :disabled="isLoading" class="w-full bg-eco-500 hover:bg-eco-600 text-white font-semibold py-2.5 rounded-lg transition-colors flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed">
                <span x-show="!isLoading">Sign In</span>
                <i x-show="isLoading" class='bx bx-loader-alt animate-spin text-xl' x-cloak></i>
                <span x-show="isLoading" x-cloak>Authenticating...</span>
            </button>
        </form>
    </div>

    <script>
        function loginForm() {
            return {
                email: '',
                password: '',
                isLoading: false,
                errorMessage: '',
                async submitAuth() {
                    this.isLoading = true;
                    this.errorMessage = '';
                    
                    try {
                        // We will build this API endpoint in NestJS next
                        const response = await fetch('/api/auth/login', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ email: this.email, password: this.password })
                        });

                        if (!response.ok) {
                            throw new Error('Invalid credentials');
                        }
                        
                        // Redirect to dashboard on success without reloading until navigation
                        window.location.href = '/admin/dashboard';
                    } catch (error) {
                        this.errorMessage = error.message;
                    } finally {
                        this.isLoading = false;
                    }
                }
            }
        }
    </script>
</body>
</html>