<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.6/quill.min.js"></script>

<style>
    /* High-end integration of Quill with Tailwind & Dark Mode */
    .ql-toolbar.ql-snow { border-radius: 0.75rem 0.75rem 0 0; border-color: #e5e7eb; background: #f9fafb; font-family: inherit; padding: 12px; }
    .ql-container.ql-snow { border-radius: 0 0 0.75rem 0.75rem; border-color: #e5e7eb; min-height: 150px; font-family: inherit; font-size: 1rem; }
    .ql-editor { padding: 1.5rem; }
    
    .dark .ql-toolbar.ql-snow { border-color: #374151; background: #1f2937; }
    .dark .ql-container.ql-snow { border-color: #374151; color: #f3f4f6; }
    .dark .ql-snow .ql-stroke { stroke: #d1d5db; }
    .dark .ql-snow .ql-fill, .dark .ql-snow .ql-stroke.ql-fill { fill: #d1d5db; }
    .dark .ql-snow .ql-picker { color: #d1d5db; }
    .dark .ql-editor.ql-blank::before { color: #9ca3af; font-style: normal; }
</style>

<div class="max-w-4xl mx-auto pb-32" x-data="blogBuilder({ 
        id: '<%- blog.id %>', 
        title: `<%- blog.title.replace(/`/g, '\\`') %>`, 
        isPublished: <%= blog.isPublished %>, 
        // We use Buffer to safely Base64 encode the complex JSON string on the server
        contentBase64: '<%- Buffer.from(blog.content).toString("base64") %>' 
    })">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <a href="/admin/blogs" class="text-sm text-purple-500 hover:text-purple-600 flex items-center gap-1 mb-2"><i class='bx bx-left-arrow-alt'></i> Back to Posts</a>
            <h1 class="text-3xl font-bold text-gray-900 dark:text-white">Write New Post</h1>
        </div>
        <button @click="submitPost" :disabled="loading" class="bg-eco-500 hover:bg-eco-600 text-white font-bold py-3 px-8 rounded-xl shadow-lg shadow-purple-500/20 flex items-center gap-2 transition-all">
            <span x-show="!loading">Apply Changes</span>
            <i x-show="loading" class='bx bx-loader-alt animate-spin text-xl' x-cloak></i>
        </button>
    </div>

    <div class="bg-white dark:bg-eco-800 rounded-2xl p-6 border border-gray-200 dark:border-gray-700 mb-8 shadow-sm flex gap-6">
        <div class="flex-1">
            <label class="block text-sm font-bold mb-2 text-gray-700 dark:text-gray-300">Blog Title</label>
            <input type="text" x-model="title" placeholder="Enter an engaging title..." required class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 outline-none focus:ring-2 focus:ring-purple-500 text-gray-900 dark:text-white font-medium">
        </div>
        <div class="w-48">
            <label class="block text-sm font-bold mb-2 text-gray-700 dark:text-gray-300">Status</label>
            <select x-model="isPublished" class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-600 bg-gray-50 dark:bg-gray-900 outline-none focus:ring-2 focus:ring-purple-500 text-gray-900 dark:text-white font-medium cursor-pointer">
                <option :value="true">Published</option>
                <option :value="false">Draft</option>
            </select>
        </div>
    </div>

    <div id="block-container" class="space-y-6">
        <template x-for="(block, index) in blocks" :key="block.id">
            <div>
                <div class="bg-white dark:bg-eco-800 rounded-2xl border border-gray-200 dark:border-gray-700 shadow-sm relative transition-all"
                     :class="{ 'border-l-4 border-l-blue-500': block.type === 'intro', 'border-l-4 border-l-green-500': block.type === 'paragraph', 'border-l-4 border-l-purple-500': block.type === 'quote', 'border-l-4 border-l-gray-500': block.type === 'conclusion' }">
                    
                    <div class="px-6 py-3 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center bg-gray-50/50 dark:bg-gray-900/20 rounded-t-2xl">
                        <span class="text-xs font-bold uppercase text-gray-500 tracking-wider flex items-center gap-2">
                            <i class='bx' :class="{'bx-align-left': block.type === 'intro', 'bx-paragraph': block.type === 'paragraph', 'bxs-quote-alt-left': block.type === 'quote', 'bx-flag': block.type === 'conclusion'}"></i>
                            <span x-text="block.type"></span>
                        </span>
                        <button @click="removeBlock(block.id)" class="text-gray-400 hover:text-red-500 transition-colors bg-white dark:bg-gray-800 rounded-full p-1 shadow-sm border border-gray-200 dark:border-gray-700" title="Delete Block">
                            <i class='bx bx-x text-lg'></i>
                        </button>
                    </div>

                    <div class="p-6">
                        <template x-if="block.type === 'paragraph' || block.type === 'conclusion'">
                            <div class="mb-4">
                                <input type="text" x-model="block.subheading" placeholder="Add a subheading (Optional)..." class="w-full px-2 py-2 border-b-2 border-transparent hover:border-gray-200 focus:border-purple-500 bg-transparent outline-none font-bold text-xl text-gray-800 dark:text-gray-100 transition-colors placeholder-gray-400">
                            </div>
                        </template>

                        <div x-init="$nextTick(() => window.initQuill(block))">
                            <div :id="'editor-' + block.id" class="bg-white dark:bg-gray-900 border-none"></div>
                        </div>
                        
                        <template x-if="block.type === 'paragraph' || block.type === 'conclusion'">
                            <div class="mt-6 pt-4 border-t border-gray-100 dark:border-gray-700 relative z-10">
                                <p class="text-[10px] font-bold text-gray-400 mb-3 tracking-widest uppercase">Attachments & Links</p>
                                
                                <div class="flex flex-wrap gap-3 mb-4" x-show="block.attachments.length > 0">
                                    <template x-for="att in block.attachments" :key="att.id">
                                        <div class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-50 dark:bg-gray-900 text-sm font-medium text-gray-700 dark:text-gray-200 border border-gray-200 dark:border-gray-700 shadow-sm">
                                            <i class='bx' :class="{'bx-image text-purple-500': att.type === 'image', 'bx-folder text-green-500': att.type === 'project', 'bx-layer text-blue-500': att.type === 'service'}"></i>
                                            <span x-text="att.label || 'New Upload'"></span>
                                            <button type="button" @click="removeAttachment(block, att.id)" class="text-red-500 hover:bg-red-50 dark:hover:bg-red-900/30 rounded-full p-0.5 ml-1"><i class='bx bx-x'></i></button>
                                        </div>
                                    </template>
                                </div>

                                <div class="flex gap-3">
                                    <label class="cursor-pointer px-4 py-2 rounded-xl bg-purple-50 text-purple-600 dark:bg-purple-900/30 hover:bg-purple-100 transition-colors text-sm font-bold flex items-center gap-2 border border-purple-100 dark:border-purple-800/50">
                                        <i class='bx bx-image-add text-lg'></i> Add Image
                                        <input type="file" accept="image/*" class="hidden" @change="attachImage(block, $event)">
                                    </label>
                                    
                                    <div class="relative" x-data="autocomplete(block, 'project', '/api/blogs/search-projects')">
                                        <button type="button" @click="open = !open" class="px-4 py-2 rounded-xl bg-green-50 text-green-600 dark:bg-green-900/30 hover:bg-green-100 transition-colors text-sm font-bold flex items-center gap-2 border border-green-100 dark:border-green-800/50">
                                            <i class='bx bx-folder text-lg'></i> Link Project
                                        </button>
                                        <div x-show="open" @click.away="open = false" class="absolute top-full left-0 mt-2 w-72 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-2xl z-50 overflow-hidden" x-transition x-cloak>
                                            <input type="text" x-model="query" @input.debounce="search" placeholder="Type to search projects..." class="w-full px-4 py-3 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 outline-none text-sm text-gray-900 dark:text-white focus:bg-white dark:focus:bg-gray-800">
                                            <div class="max-h-48 overflow-y-auto">
                                                <template x-for="res in results">
                                                    <div @click="select(res.id, res.title)" class="px-4 py-3 hover:bg-green-50 dark:hover:bg-green-900/30 cursor-pointer text-sm font-medium border-b border-gray-50 dark:border-gray-700/50 text-gray-700 dark:text-gray-200 flex items-center gap-2" x-text="res.title"></div>
                                                </template>
                                                <div x-show="query.length > 1 && results.length === 0" class="px-4 py-3 text-sm text-gray-500">No projects found.</div>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="relative" x-data="autocomplete(block, 'service', '/api/blogs/search-services')">
                                        <button type="button" @click="open = !open" class="px-4 py-2 rounded-xl bg-blue-50 text-blue-600 dark:bg-blue-900/30 hover:bg-blue-100 transition-colors text-sm font-bold flex items-center gap-2 border border-blue-100 dark:border-blue-800/50">
                                            <i class='bx bx-layer text-lg'></i> Link Service
                                        </button>
                                        <div x-show="open" @click.away="open = false" class="absolute top-full left-0 mt-2 w-72 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl shadow-2xl z-50 overflow-hidden" x-transition x-cloak>
                                            <input type="text" x-model="query" @input.debounce="search" placeholder="Type to search services..." class="w-full px-4 py-3 border-b border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 outline-none text-sm text-gray-900 dark:text-white focus:bg-white dark:focus:bg-gray-800">
                                            <div class="max-h-48 overflow-y-auto">
                                                <template x-for="res in results">
                                                    <div @click="select(res.id, res.name)" class="px-4 py-3 hover:bg-blue-50 dark:hover:bg-blue-900/30 cursor-pointer text-sm font-medium border-b border-gray-50 dark:border-gray-700/50 text-gray-700 dark:text-gray-200 flex items-center gap-2" x-text="res.name"></div>
                                                </template>
                                                <div x-show="query.length > 1 && results.length === 0" class="px-4 py-3 text-sm text-gray-500">No services found.</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </template>
                    </div>
                </div>

                <div class="flex items-center gap-2 justify-center py-6 opacity-40 hover:opacity-100 transition-opacity group-hover:opacity-100">
                    <hr class="flex-1 border-gray-300 dark:border-gray-600 border-dashed">
                    <button type="button" @click="insertBlock(index + 1, 'intro')" class="hover:bg-blue-50 hover:text-blue-600 dark:hover:bg-gray-700 text-gray-500 px-3 py-1.5 rounded-lg transition-colors text-xs font-bold flex items-center gap-1"><i class='bx bx-align-left'></i> Intro</button>
                    <button type="button" @click="insertBlock(index + 1, 'paragraph')" class="hover:bg-green-50 hover:text-green-600 dark:hover:bg-gray-700 text-gray-500 px-3 py-1.5 rounded-lg transition-colors text-xs font-bold flex items-center gap-1"><i class='bx bx-paragraph'></i> Paragraph</button>
                    <button type="button" @click="insertBlock(index + 1, 'quote')" class="hover:bg-purple-50 hover:text-purple-600 dark:hover:bg-gray-700 text-gray-500 px-3 py-1.5 rounded-lg transition-colors text-xs font-bold flex items-center gap-1"><i class='bx bxs-quote-alt-left'></i> Quote</button>
                    <button type="button" @click="insertBlock(index + 1, 'conclusion')" class="hover:bg-gray-100 hover:text-gray-900 dark:hover:bg-gray-700 text-gray-500 px-3 py-1.5 rounded-lg transition-colors text-xs font-bold flex items-center gap-1"><i class='bx bx-flag'></i> Conclusion</button>
                    <hr class="flex-1 border-gray-300 dark:border-gray-600 border-dashed">
                </div>
            </div>
        </template>
    </div>

    <div class="fixed bottom-6 left-1/2 -translate-x-1/2 ml-32 bg-white dark:bg-eco-800 px-6 py-3 rounded-full shadow-[0_10px_40px_rgba(0,0,0,0.2)] border border-gray-200 dark:border-gray-700 flex items-center gap-2 z-40">
        <span class="text-xs font-bold text-gray-400 mr-2 border-r border-gray-200 dark:border-gray-700 pr-4">ADD BLOCK</span>
        <button @click="addBlock('intro')" class="hover:bg-blue-50 hover:text-blue-600 text-gray-600 dark:text-gray-300 px-3 py-1.5 rounded-lg transition-colors text-sm font-medium"><i class='bx bx-align-left'></i> Intro</button>
        <button @click="addBlock('paragraph')" class="hover:bg-green-50 hover:text-green-600 text-gray-600 dark:text-gray-300 px-3 py-1.5 rounded-lg transition-colors text-sm font-medium"><i class='bx bx-paragraph'></i> Paragraph</button>
        <button @click="addBlock('quote')" class="hover:bg-purple-50 hover:text-purple-600 text-gray-600 dark:text-gray-300 px-3 py-1.5 rounded-lg transition-colors text-sm font-medium"><i class='bx bxs-quote-alt-left'></i> Quote</button>
        <button @click="addBlock('conclusion')" class="hover:bg-gray-100 hover:text-gray-900 text-gray-600 dark:text-gray-300 px-3 py-1.5 rounded-lg transition-colors text-sm font-medium"><i class='bx bx-flag'></i> Conclusion</button>
    </div>
</div>

<script>
// Global Unique ID Generator (Safe outside Alpine scope)
function generateSafeId() {
    return Date.now().toString() + Math.random().toString(16).slice(2, 8);
}

// Global Quill Initializer (Triggered by Alpine's $nextTick)
window.initQuill = function(block) {
    const editorContainer = document.getElementById('editor-' + block.id);
    if (!editorContainer || editorContainer.classList.contains('ql-container')) return;

    const q = new Quill(editorContainer, {
        theme: 'snow',
        placeholder: 'Write your ' + block.type + ' content here...',
        modules: { toolbar: [['bold', 'italic', 'underline'], [{ 'list': 'ordered'}, { 'list': 'bullet' }], ['link', 'clean']] }
    });
    
    if (block.content) q.root.innerHTML = block.content;
    q.on('text-change', () => { block.content = q.root.innerHTML; });
};

// Main Alpine Component
function blogBuilder(initialData = null) {
    let initialBlocks = [{ id: generateSafeId(), type: 'intro', subheading: '', content: '', attachments: [] }];
    
    // Safely decode the Base64 string back into the JSON array
    if (initialData && initialData.contentBase64) {
        try {
            // atob() decodes Base64 in the browser natively
            const decodedJson = atob(initialData.contentBase64);
            initialBlocks = JSON.parse(decodedJson);
        } catch (e) {
            console.error("Failed to parse initial blog content:", e);
        }
    }

    return {
        title: initialData ? initialData.title : '',
        isPublished: initialData ? initialData.isPublished : false,
        blocks: initialBlocks,
        loading: false,

        // Adds to the very end of the document
        addBlock(type) {
            this.blocks.push({ id: generateSafeId(), type, subheading: '', content: '', attachments: [] });
        },
        
        // Inserts immediately after the block where the button was clicked
        insertBlock(index, type) {
            this.blocks.splice(index, 0, { id: generateSafeId(), type, subheading: '', content: '', attachments: [] });
        },

        removeBlock(id) {
            if (confirm('Delete this block?')) {
                this.blocks = this.blocks.filter(b => b.id !== id);
            }
        },

        attachImage(block, event) {
            const file = event.target.files[0];
            if (file) {
                block.attachments.push({ id: generateSafeId(), type: 'image', fileObj: file, label: file.name });
            }
            event.target.value = '';
        },

        removeAttachment(block, attId) {
            block.attachments = block.attachments.filter(a => a.id !== attId);
        },

        async submitPost() {
            if (!this.title) return alert('Please enter a Blog Title');
            if (this.blocks.length === 0) return alert('Please add at least one content block');
            this.loading = true;

            const fd = new FormData();
            fd.append('title', this.title);
            fd.append('isPublished', this.isPublished);

            const cleanBlocks = this.blocks.map(b => ({
                id: b.id, type: b.type, subheading: b.subheading || '', content: b.content,
                attachments: b.attachments.map(a => ({ id: a.id, type: a.type, refId: a.refId, url: a.url, label: a.label }))
            }));
            
            fd.append('content', JSON.stringify(cleanBlocks));

            this.blocks.forEach(b => {
                b.attachments.forEach(a => {
                    if (a.type === 'image' && a.fileObj) {
                        fd.append(`file_${b.id}_${a.id}`, a.fileObj);
                    }
                });
            });

            try {
                const url = initialData ? `/api/blogs/${initialData.id}` : '/api/blogs';
                const method = initialData ? 'PUT' : 'POST';
                const res = await fetch(url, { method, body: fd });
                if (res.ok) window.location.href = '/admin/blogs';
                else throw new Error('Submission failed');
            } catch (err) {
                alert(err.message);
            } finally {
                this.loading = false;
            }
        }
    }
}

// Reusable Autocomplete Logic for Dropdowns
function autocomplete(block, type, apiUrl) {
    return {
        open: false, query: '', results: [],
        async search() {
            if (this.query.length < 2) { this.results = []; return; }
            try {
                const res = await fetch(`${apiUrl}?q=${this.query}`);
                this.results = await res.json();
            } catch (err) { console.error('Search failed', err); }
        },
        select(id, label) {
            block.attachments.push({ id: generateSafeId(), type, refId: id, label });
            this.open = false; 
            this.query = '';
        }
    }
}
</script>