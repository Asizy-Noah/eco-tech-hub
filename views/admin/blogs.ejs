<div class="flex items-center justify-between mb-8">
    <div>
        <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Sustainability Blog</h1>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Manage articles, thoughts, and publications.</p>
    </div>
    <a href="/admin/blogs/new" class="bg-eco-500 hover:bg-eco-600 text-white px-4 py-2 rounded-lg font-medium transition-colors shadow-sm flex items-center gap-2">
        <i class='bx bx-plus text-xl'></i> Write Post
    </a>
</div>

<div class="bg-white dark:bg-eco-800 rounded-2xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead class="bg-gray-50 dark:bg-gray-900/50">
            <tr>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Title</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Status</th>
                <th class="px-6 py-4 text-xs font-semibold text-gray-500 uppercase">Date</th>
                <th class="px-6 py-4 text-right text-xs font-semibold text-gray-500 uppercase">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-gray-200 dark:divide-gray-700">
            <% if (blogs.length === 0) { %>
                <tr><td colspan="4" class="px-6 py-12 text-center text-gray-500">No posts yet. Start writing!</td></tr>
            <% } else { %>
                <% blogs.forEach(blog => { %>
                    <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/50">
                        <td class="px-6 py-4 font-bold text-gray-900 dark:text-white"><%= blog.title %></td>
                        <td class="px-6 py-4">
                            <% if (blog.isPublished) { %>
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-green-100 text-green-800">Published</span>
                            <% } else { %>
                                <span class="px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-800">Draft</span>
                            <% } %>
                        </td>
                        <td class="px-6 py-4 text-sm text-gray-500"><%= new Date(blog.createdAt).toLocaleDateString() %></td>
                        <td class="px-6 py-4 text-right space-x-3">
                            <a href="/admin/blogs/edit/<%= blog.id %>" class="text-gray-400 hover:text-purple-500"><i class='bx bx-edit text-xl'></i></a>
                            <button x-data @click="if(confirm('Delete post?')) fetch('/api/blogs/<%= blog.id %>', { method: 'DELETE' }).then(() => window.location.reload())" class="text-gray-400 hover:text-red-500"><i class='bx bx-trash text-xl'></i></button>
                        </td>
                    </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</div>