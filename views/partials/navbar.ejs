<nav x-data="{ 
  scrollY: 0,
  lastScrollY: 0,
  isHidden: false,
  mobileOpen: false,
  searchOpen: false,
  theme: localStorage.getItem('theme') || 'light',
  
  init() {
    this.theme = document.documentElement.classList.contains('dark') ? 'dark' : 'light';
  },
  
  toggleTheme() {
    this.theme = this.theme === 'dark' ? 'light' : 'dark';
    localStorage.setItem('theme', this.theme);
    if (this.theme === 'dark') {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  },
  
  handleScroll() {
    this.scrollY = window.scrollY;
    
    // Hide navbar when scrolling down past 80px threshold
    if (this.scrollY > this.lastScrollY && this.scrollY > 80) {
      this.isHidden = true;
    } 
    // Show navbar when scrolling up
    else if (this.scrollY < this.lastScrollY) {
      this.isHidden = false;
    }
    
    this.lastScrollY = this.scrollY;
  }
}" 
@scroll.window.passive="handleScroll()"
@click.outside="mobileOpen = false"
class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 ease-out"
:class="isHidden ? '-translate-y-full' : 'translate-y-0'">

  <!-- Navbar Container -->
  <div class="backdrop-blur-2xl bg-white/95 dark:bg-[#0a0a0a]/95 border-b border-black/5 dark:border-white/5 shadow-sm dark:shadow-none">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-14 sm:h-16 md:h-20">
        
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2 group z-50 flex-shrink-0">
          <div class="w-8 h-8 sm:w-9 md:w-10 rounded-lg bg-gradient-to-br from-eco-400 to-eco-600 flex items-center justify-center text-white text-xs sm:text-sm font-bold transform group-hover:scale-110 transition-transform duration-300 shadow-lg shadow-eco-500/30">
            ET
          </div>
          <span class="hidden xs:block font-bold text-sm sm:text-base md:text-lg tracking-tight text-black dark:text-white">Eco<span class="hidden sm:inline">Tech</span><span class="text-eco-500">.</span></span>
        </a>

        <!-- Desktop Navigation -->
        <div class="hidden lg:flex items-center gap-6 xl:gap-8">
          <a href="/#services" class="text-xs md:text-sm font-medium text-black/60 dark:text-white/60 hover:text-eco-600 dark:hover:text-eco-400 transition-colors duration-200 relative group">
            Services
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-eco-500 group-hover:w-full transition-all duration-300"></span>
          </a>
          <a href="/#portfolio" class="text-xs md:text-sm font-medium text-black/60 dark:text-white/60 hover:text-eco-600 dark:hover:text-eco-400 transition-colors duration-200 relative group">
            Portfolio
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-eco-500 group-hover:w-full transition-all duration-300"></span>
          </a>
          <a href="/#blog" class="text-xs md:text-sm font-medium text-black/60 dark:text-white/60 hover:text-eco-600 dark:hover:text-eco-400 transition-colors duration-200 relative group">
            Journal
            <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-eco-500 group-hover:w-full transition-all duration-300"></span>
          </a>
        </div>

        <!-- Right Actions -->
        <div class="flex items-center gap-2 sm:gap-4">
          <!-- Search (Desktop) -->
          <div class="hidden md:flex items-center">
            <div class="relative">
              <input type="text" 
                     placeholder="Search..." 
                     class="hidden sm:block w-0 group-focus-within:w-48 bg-black/5 dark:bg-white/5 border border-black/10 dark:border-white/10 text-black dark:text-white placeholder-black/40 dark:placeholder-white/40 px-3 py-2 rounded-full text-xs transition-all duration-300 focus:outline-none focus:border-eco-500"
                     @focus="$el.parentElement.classList.add('w-48')"
                     @blur="$el.parentElement.classList.remove('w-48')">
            </div>
          </div>

          <!-- Theme Toggle -->
          <button @click="toggleTheme()" 
                  class="w-9 h-9 sm:w-10 sm:h-10 rounded-full flex items-center justify-center bg-black/5 dark:bg-white/10 hover:bg-black/10 dark:hover:bg-white/20 text-black dark:text-white transition-colors duration-200"
                  :title="theme === 'dark' ? 'Light mode' : 'Dark mode'">
            <i class='bx text-lg sm:text-xl transition-transform duration-500' :class="theme === 'dark' ? 'bx-sun text-yellow-400' : 'bx-moon'"></i>
          </button>

          <!-- CTA Button (Desktop) -->
          <a href="/#contact" class="hidden md:flex px-4 lg:px-6 py-2 lg:py-2.5 rounded-full bg-black dark:bg-white text-white dark:text-black font-bold text-xs lg:text-sm uppercase tracking-wide hover:shadow-lg hover:shadow-black/30 dark:hover:shadow-eco-500/30 transform hover:scale-110 transition-all duration-300 active:scale-95">
            Talk
            <span class="hidden lg:inline ml-1">Now</span>
          </a>

          <!-- Mobile Menu Button -->
          <button @click="mobileOpen = !mobileOpen" 
                  class="lg:hidden w-9 h-9 flex items-center justify-center text-black dark:text-white">
            <i class='bx text-2xl transition-transform duration-300' :class="mobileOpen ? 'bx-x' : 'bx-menu'"></i>
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div x-show="mobileOpen"
       x-transition:enter="transition ease-out duration-300"
       x-transition:enter-start="opacity-0 -translate-y-2"
       x-transition:enter-end="opacity-100 translate-y-0"
       x-transition:leave="transition ease-in duration-200"
       x-transition:leave-start="opacity-100 translate-y-0"
       x-transition:leave-end="opacity-0 -translate-y-2"
       class="lg:hidden backdrop-blur-2xl bg-white/98 dark:bg-[#0a0a0a]/98 border-b border-black/5 dark:border-white/5">
    
    <div class="max-w-7xl mx-auto px-3 sm:px-6 lg:px-8 py-3 space-y-0.5">
      <a href="/#services" @click="mobileOpen = false" class="block px-3 py-2.5 text-sm font-medium text-black dark:text-white hover:bg-eco-50 dark:hover:bg-white/5 rounded-lg transition-colors duration-200">
        Services
      </a>
      <a href="/#portfolio" @click="mobileOpen = false" class="block px-3 py-2.5 text-sm font-medium text-black dark:text-white hover:bg-eco-50 dark:hover:bg-white/5 rounded-lg transition-colors duration-200">
        Portfolio
      </a>
      <a href="/#blog" @click="mobileOpen = false" class="block px-3 py-2.5 text-sm font-medium text-black dark:text-white hover:bg-eco-50 dark:hover:bg-white/5 rounded-lg transition-colors duration-200">
        Journal
      </a>
      <div class="my-2 border-t border-black/5 dark:border-white/5"></div>
      <a href="/#contact" @click="mobileOpen = false" class="block px-3 py-2.5 text-sm font-bold text-white bg-eco-600 dark:bg-eco-600 hover:bg-eco-700 rounded-lg transition-colors duration-200">
        Get In Touch
      </a>
    </div>
  </div>
</nav>
