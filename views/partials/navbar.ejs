<nav x-data="{ 
        atTop: true, 
        lastScroll: 0, 
        isHidden: false, 
        searchOpen: false, 
        mobileMenu: false,
        theme: document.documentElement.classList.contains('dark') ? 'dark' : 'light',
        toggleTheme() {
            this.theme = this.theme === 'dark' ? 'light' : 'dark';
            localStorage.setItem('theme', this.theme);
            if (this.theme === 'dark') document.documentElement.classList.add('dark');
            else document.documentElement.classList.remove('dark');
        }
    }" 
    @scroll.window="
        let current = window.pageYOffset;
        atTop = current <= 20;
        /* Hide if scrolling down past 100px, show if scrolling up */
        if (current > lastScroll && current > 100) { isHidden = true; } 
        else { isHidden = false; }
        lastScroll = current;
    "
    :class="{ 
        '-translate-y-full': isHidden, 
        'bg-white/80 dark:bg-gray-900/80 backdrop-blur-lg shadow-sm border-b border-gray-200/50 dark:border-gray-800/50': !atTop, 
        'bg-transparent border-transparent py-2': atTop 
    }"
    class="fixed top-0 left-0 w-full z-50 transition-all duration-500 transform border-b"
>
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="flex justify-between items-center h-20 transition-all duration-300">
            
            <a href="/" class="flex items-center gap-2 group z-50">
                <div class="w-10 h-10 rounded-xl bg-eco-500/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
                    <i class='bx bx-leaf text-eco-500 text-2xl'></i>
                </div>
                <span class="font-black text-2xl tracking-tight text-gray-900 dark:text-white">Eco Tech Hub<span class="text-eco-500">.</span></span>
            </a>

            <div class="hidden md:flex items-center gap-8 font-semibold text-sm text-gray-600 dark:text-gray-300">
                <a href="/#services" class="hover:text-eco-500 transition-colors">Services</a>
                <a href="/#portfolio" class="hover:text-eco-500 transition-colors">Portfolio</a>
                <a href="/#blog" class="hover:text-eco-500 transition-colors">Journal</a>
            </div>

            <div class="hidden md:flex items-center gap-5">
                <div class="flex items-center">
                    <div class="flex items-center bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden transition-all duration-300 ease-in-out" 
                         :class="searchOpen ? 'w-48 opacity-100 px-4 mr-2' : 'w-0 opacity-0 px-0'">
                        <input type="text" placeholder="Search..." class="bg-transparent outline-none w-full text-sm py-2 text-gray-900 dark:text-white placeholder-gray-500">
                    </div>
                    <button @click="searchOpen = !searchOpen" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-300 transition-colors focus:outline-none">
                        <i class='bx bx-search text-xl'></i>
                    </button>
                </div>

                <button @click="toggleTheme()" class="w-10 h-10 rounded-full flex items-center justify-center hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-600 dark:text-gray-300 transition-colors focus:outline-none">
                    <i class='bx text-xl transition-transform duration-300' :class="theme === 'dark' ? 'bx-sun rotate-180 text-yellow-400' : 'bx-moon -rotate-12'"></i>
                </button>

                <a href="/#contact" class="px-6 py-2.5 rounded-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold text-sm hover:scale-105 hover:shadow-lg transition-all duration-300">
                    Let's Talk
                </a>
            </div>

            <button @click="mobileMenu = !mobileMenu" class="md:hidden w-10 h-10 flex items-center justify-center text-gray-600 dark:text-gray-300 focus:outline-none z-50 relative">
                <i class='bx text-3xl transition-transform duration-300' :class="mobileMenu ? 'bx-x rotate-90' : 'bx-menu'"></i>
            </button>
        </div>
    </div>

    <div x-show="mobileMenu" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 -translate-y-full"
         x-transition:enter-end="opacity-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 translate-y-0"
         x-transition:leave-end="opacity-0 -translate-y-full"
         x-cloak 
         class="md:hidden fixed inset-0 top-0 pt-24 bg-white dark:bg-gray-900 z-40 flex flex-col h-screen">
        <div class="px-8 py-8 space-y-6 font-bold text-2xl flex flex-col text-gray-900 dark:text-white">
            <a href="/#services" @click="mobileMenu = false" class="hover:text-eco-500 transition-colors border-b border-gray-100 dark:border-gray-800 pb-4">Services</a>
            <a href="/#portfolio" @click="mobileMenu = false" class="hover:text-eco-500 transition-colors border-b border-gray-100 dark:border-gray-800 pb-4">Portfolio</a>
            <a href="/#blog" @click="mobileMenu = false" class="hover:text-eco-500 transition-colors border-b border-gray-100 dark:border-gray-800 pb-4">Sustainability Journal</a>
            <a href="/#contact" @click="mobileMenu = false" class="text-eco-500">Contact Us</a>
            
            <div class="flex items-center gap-4 mt-8 pt-8 border-t border-gray-100 dark:border-gray-800">
                <span class="text-base text-gray-500">Theme</span>
                <button @click="toggleTheme()" class="w-12 h-12 rounded-full flex items-center justify-center bg-gray-100 dark:bg-gray-800 text-gray-900 dark:text-white">
                    <i class='bx text-2xl' :class="theme === 'dark' ? 'bx-sun text-yellow-400' : 'bx-moon'"></i>
                </button>
            </div>
        </div>
    </div>
</nav>