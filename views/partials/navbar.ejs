<div x-data="{ 
        atTop: true, 
        lastScrollY: window.scrollY, 
        isHidden: false, 
        searchOpen: false, 
        mobileMenu: false,
        theme: document.documentElement.classList.contains('dark') ? 'dark' : 'light',
        
        toggleTheme() {
            this.theme = this.theme === 'dark' ? 'light' : 'dark';
            localStorage.setItem('theme', this.theme);
            if (this.theme === 'dark') {
                document.documentElement.classList.add('dark');
            } else {
                document.documentElement.classList.remove('dark');
            }
        }
    }" 
    @scroll.window="
        let currentY = window.scrollY;
        atTop = currentY <= 20;
        /* Hides when scrolling down, shows when scrolling up */
        if (currentY > lastScrollY && currentY > 100) { isHidden = true; } 
        else if (currentY < lastScrollY) { isHidden = false; }
        lastScrollY = currentY;
    "
    class="fixed top-0 left-0 right-0 z-50 p-4 sm:p-6 flex justify-center pointer-events-none transition-transform duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]"
    :class="isHidden ? '-translate-y-full' : 'translate-y-0'"
>
    <nav class="w-full max-w-5xl bg-white/80 dark:bg-black/80 backdrop-blur-xl border border-black/10 dark:border-white/10 shadow-lg rounded-full px-6 py-3 flex justify-between items-center pointer-events-auto transition-all duration-300"
         :class="searchOpen ? 'max-w-6xl' : 'max-w-5xl'">
         
        <a href="/" class="flex items-center gap-2 group z-50">
            <i class='bx bx-leaf text-eco-500 text-2xl transition-transform transform-gpu group-hover:-rotate-12'></i>
            <span class="font-bold text-lg tracking-tight text-black dark:text-white">Eco Tech Hub<span class="text-eco-500">.</span></span>
        </a>

        <div class="hidden md:flex items-center gap-8 font-semibold text-sm text-black/60 dark:text-white/60">
            <a href="/services" class="hover:text-black dark:hover:text-white transition-colors">Services</a>
            <a href="/projects" class="hover:text-black dark:hover:text-white transition-colors">Portfolio</a>
            <a href="/blog" class="hover:text-black dark:hover:text-white transition-colors">Journal</a>
        </div>

        <div class="hidden md:flex items-center gap-2">
            
            <div class="flex items-center bg-black/5 dark:bg-white/5 rounded-full overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)]" 
                 :class="searchOpen ? 'w-48 opacity-100 px-4 mr-2' : 'w-0 opacity-0 px-0'">
                <input type="text" placeholder="Search..." class="bg-transparent outline-none w-full text-sm py-2 text-black dark:text-white placeholder-black/40 dark:placeholder-white/40">
            </div>
            <button @click="searchOpen = !searchOpen" class="w-9 h-9 rounded-full flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/10 text-black/80 dark:text-white/80 transition-colors">
                <i class='bx bx-search text-lg'></i>
            </button>

            <button @click="toggleTheme()" class="w-9 h-9 rounded-full flex items-center justify-center hover:bg-black/5 dark:hover:bg-white/10 text-black/80 dark:text-white/80 transition-colors">
                <i class='bx text-lg transition-transform duration-500' :class="theme === 'dark' ? 'bx-sun text-yellow-400 rotate-180' : 'bx-moon -rotate-12'"></i>
            </button>

            <a href="/contact" class="ml-2 px-5 py-2.5 rounded-full bg-black dark:bg-white text-white dark:text-black font-bold text-xs uppercase tracking-widest hover:scale-105 transition-transform duration-300">
                Let's Talk
            </a>
        </div>

        <button @click="mobileMenu = !mobileMenu" class="md:hidden w-10 h-10 flex items-center justify-end text-black dark:text-white z-50">
            <i class='bx text-2xl transition-transform' :class="mobileMenu ? 'bx-x' : 'bx-menu'"></i>
        </button>
    </nav>

    <div x-show="mobileMenu" 
         x-transition:enter="transition ease-out duration-300"
         x-transition:enter-start="opacity-0 scale-95 -translate-y-4"
         x-transition:enter-end="opacity-100 scale-100 translate-y-0"
         x-transition:leave="transition ease-in duration-200"
         x-transition:leave-start="opacity-100 scale-100 translate-y-0"
         x-transition:leave-end="opacity-0 scale-95 -translate-y-4"
         x-cloak 
         class="md:hidden absolute top-[80px] left-4 right-4 bg-white/95 dark:bg-black/95 backdrop-blur-xl border border-black/10 dark:border-white/10 rounded-3xl p-6 shadow-2xl pointer-events-auto flex flex-col gap-6">
        
        <a href="/services" @click="mobileMenu = false" class="text-2xl font-bold text-black dark:text-white hover:text-eco-500 transition-colors">Services</a>
        <a href="/projects" @click="mobileMenu = false" class="text-2xl font-bold text-black dark:text-white hover:text-eco-500 transition-colors">Portfolio</a>
        <a href="/blog" @click="mobileMenu = false" class="text-2xl font-bold text-black dark:text-white hover:text-eco-500 transition-colors">Journal</a>
        
        <hr class="border-black/10 dark:border-white/10">
        
        <div class="flex justify-between items-center">
            <a href="/contact" @click="mobileMenu = false" class="text-eco-500 font-bold uppercase tracking-widest text-sm">Contact Us</a>
            
            <button @click="toggleTheme()" class="w-12 h-12 rounded-full flex items-center justify-center bg-black/5 dark:bg-white/10 text-black dark:text-white">
                <i class='bx text-xl transition-transform duration-500' :class="theme === 'dark' ? 'bx-sun text-yellow-400 rotate-180' : 'bx-moon'"></i>
            </button>
        </div>
    </div>
</div>